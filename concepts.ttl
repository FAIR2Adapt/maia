<http://connectivity-hub.com/terms/e8cb3cd2-9e41-4a64-9359-93f59a21d152>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "SF6, a greenhouse gas (GHG), is mainly used in heavy industry to insulate high-voltage equipment and to assist in the manufacturing of cable-cooling systems and semiconductors."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Sulphur hexafluoride (SF6)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

