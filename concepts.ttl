<http://connectivity-hub.com/terms/b1591a07-011e-42d7-bc9c-c365df423bf0>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The full costs of an action in terms of social welfare losses, including external costs associated with the impacts of this action on the environment, the economy (GDP, employment) and on the society as a whole."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Social costs"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

