<http://connectivity-hub.com/terms/4a5d61d4-33ee-40ac-b4ac-e0ae80c75865>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The climate response pattern in space and/or time to a specific forcing is commonly referred to as a fingerprint. The spatial patterns of sea level response to melting of glaciers or ice sheets (or other changes in surface loading) are also referred to as fingerprints. Fingerprints are used to detect the presence of this response in observations and are typically estimated using forced climate model simulations."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Fingerprint"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

