<http://connectivity-hub.com/terms/e36ea8ae-a216-48ac-9ecc-8f0771e4d1f5>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Acute food insecurity is a situation which can occur at any time with a severity that threatens lives, livelihoods or both, regardless of the causes,context or duration, as a result of shocks risking determinants of food security and nutrition, and used to assess the need for humanitarian action (IPC Global Partners, 2019 in IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Acute food insecurity"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

