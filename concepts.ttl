<http://connectivity-hub.com/terms/56f699c6-6b41-4bd6-975b-200ca838f8c6>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Change from one land cover class to another, due to change in land use or change in natural conditions (Pongratz et al., 2018)."@en;
