<http://connectivity-hub.com/terms/84806343-3d51-4755-a5f4-82f69f718890>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Originally, a term referring to the tracks of individual cyclonic weather systems, but now often generalized to refer to the main regions where the tracks of extratropical disturbances occur as sequences of low (cyclonic) and high (anticyclonic) pressure systems."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Storm tracks"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

