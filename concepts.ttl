<http://connectivity-hub.com/terms/f372068e-5377-45c0-b9b1-01df33247d99>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Chemical process by which carbon dioxide (CO2) is captured directly from the ambient air, with subsequent storage. Also known as direct air capture and storage (DACS)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Direct air carbon dioxide capture and storage (DACCS)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

