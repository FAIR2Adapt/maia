<http://connectivity-hub.com/terms/631985c2-375f-4cc4-9a57-c27458699a26>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A phenomena of rapid warming in the stratosphere at high latitudes (sometimes more than 50°C in 1–2 days) that can cause breakdown of stratospheric polar vortices."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Sudden stratospheric warming (SSW)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

