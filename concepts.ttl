<http://connectivity-hub.com/terms/affa52fc-b12e-443d-8710-33250d80e9eb>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The consequences of realised risks on natural and human systems, where risks result from the interactions of climate-related hazards (including extreme weather/climate events), exposure, and vulnerability. Impacts generally refer to effects on lives, livelihoods, health and well-being, ecosystems and species, economic, social and cultural assets, services (including ecosystem services), and infrastructure. Impacts may be referred to as consequences or outcomes, and can be adverse or beneficial."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Impacts"@en;
        skos:related        <http://connectivity-hub.com/terms/18785e0a-e448-4cd3-99e7-d316f055513d>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
