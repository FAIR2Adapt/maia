<http://connectivity-hub.com/terms/3206b76e-81d7-48a8-a5f9-6defa1612ddf>
        rdf:type            skos:Concept;
        dc:modified         "2025-04-21T09:15:01.654Z"^^xsd:dateTime;
        skos:definition     "The capacity of a population to safeguard sustainable access to adequate quantities of acceptable quality water for sustaining livelihoods, human well-being, and socio-economic development, for ensuring protection against water-borne pollution and water-related disasters, and for preserving ecosystems in a climate of peace and political stability (UN-Water, 2013)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Water security"@en;
        skos:related        <http://connectivity-hub.com/terms/d9621e9b-33e1-49b0-976c-5c91d81f4d54>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
PREFIX dc:      <http://purl.org/dc/terms/>
PREFIX dct:     <http://purl.org/dc/terms/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dme:     <https://grafsync.graphifi.com/schema/dm-entitlement/>
PREFIX ent:     <https://graphifi.com/schema/entitlement/>
PREFIX gs:      <https://grafsync.graphifi.com/schema/gs/>
PREFIX ome:     <https://grafsync.graphifi.com/schema/om-entitlement/>
PREFIX owl:     <http://www.w3.org/2002/07/owl#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema:  <http://schema.org/>
