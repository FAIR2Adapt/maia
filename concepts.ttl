<http://connectivity-hub.com/terms/f0ac6c8d-b2ef-426b-be9b-21228fa7de51>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Direct thermally driven zonal overturning circulation in the atmosphere over the tropical Pacific Ocean, with rising air in the western and sinking air in the eastern Pacific."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Walker circulation"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

