<http://connectivity-hub.com/terms/494fd1a9-4f55-494c-b1a9-1ba83e721bbd>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Mathematical method used to combine different sources of information in order to produce the best possible estimate of the state of a system. This information usually consists of observations of the system and a numerical model of the system evolution. Data assimilation techniques are used to create initial conditions for weather forecast models and to construct reanalyses describing the trajectory of the climate system over the time period covered by the observations."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Data assimilation"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

