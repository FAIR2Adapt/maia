<http://connectivity-hub.com/terms/7c4de168-1d34-4e0c-bcc9-63e8234a2ed9>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Eastern boundary upwelling systems (EBUS) are located at the eastern (landward) edges of major ocean basins in both hemispheres, where equatorward winds drive upwelling currents that bring cool, nutrient-rich (and often oxygen-poor) waters from the deep ocean to the surface near the coast."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Eastern boundary upwelling systems (EBUS)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

