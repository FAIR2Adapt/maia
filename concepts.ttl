<http://connectivity-hub.com/terms/eb428fe0-aabb-466f-aa58-2f24e836c946>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Associated with persistent, slow-moving high-pressure systems that obstruct the prevailing westerly winds in the middle and high latitudes and the normal eastward progress of extratropical transient storm systems. It is an important component of the intra-seasonal climate variability in the extratropics and can cause long-lived weather conditions such as cold spells in winter and summer heatwaves."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Blocking"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

