<http://connectivity-hub.com/terms/4d999e64-6409-471a-aa71-7e2aa5bcdbaf>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The largest mode of tropical atmospheric intra-seasonal variability with typical periods ranging from 20 to 90 days. The MJO corresponds to planetary-scale disturbances of pressure, wind and deep convection moving predominantly eastward along the equator. As it progresses, the MJO is associated with the temporal alternation of large-scale enhanced and suppressed rainfall, with maximum loading over the Indian and western Pacific oceans, although influences of the MJO can be tracked over the Atlantic/Africa in dynamical fields. See Section AIV.2.8 in Annex IV of the AR6 WGI report."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Madden–Julian Oscillation (MJO)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

