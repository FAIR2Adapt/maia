<http://connectivity-hub.com/terms/6dfd7021-1293-49ac-b282-79fc5a181542>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A quasi-regular modulation of solar activity with varying amplitude and a period of between 8 and 14 years."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Solar ('11-year') cycle"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

