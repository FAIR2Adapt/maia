<http://connectivity-hub.com/terms/6969827a-7304-4f04-9312-a255ebbfe567>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The surface temperature response for the hypothetical scenario in which atmospheric carbon dioxide (CO2) increases at 1% yr-1 from pre-industrial to the time of a doubling of atmospheric CO2 concentration (year 70)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Transient climate response (TCR)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

