<http://connectivity-hub.com/terms/6131c736-53bb-4c8b-b0bd-07e27e153e84>
        rdf:type           skos:Concept;
        dc:created         "2025-06-06T14:24:37.36Z"^^xsd:dateTime;
        dc:modified        "2025-06-06T14:26:01.922Z"^^xsd:dateTime;
        skos:definition    "Scoping involves the synthesis and analysis of a wide range of research and non-research material to provide greater conceptual clarity about a specific topic or field of evidence (Davis et al., 2019)."@en;
        skos:historyNote   "Davis K, Drey N, Gould D: What are scoping studies? A review of the nursing literature. Int J Nurs Stud. 2009, 46: 1386-1400. 10.1016/j.ijnurstu.2009.02.010."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Scoping"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      3 .

