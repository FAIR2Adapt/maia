<http://connectivity-hub.com/terms/b3643f75-450b-4f1a-b96b-cd32a8d39d71>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The negative effects that a policy or measure aimed at one objective might have on other objectives, irrespective of the net effect on overall social welfare. Adverse side effects are often subject to uncertainty and depend on local circumstances and implementation practices, among other factors (IPCC AR5, 2014)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Adverse side effects"@en;
        skos:related        <http://connectivity-hub.com/terms/7985e474-e2b6-419c-9147-3fca7707b23d>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       3 .

