<http://connectivity-hub.com/terms/6c990046-620c-4bea-b94d-2355970890ca>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Time when a specific anthropogenic signal related to climate change is statistically detected to emerge from the background noise of natural climate variability in a reference period, for a specific region (Hawkins and Sutton, 2012)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Time of emergence (ToE)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

