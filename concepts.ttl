<http://connectivity-hub.com/terms/0873df6e-97ed-4142-9591-c9d369130aad>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Various services (such as illumination and mobility) can be provided by ‘systems’ through the use of energy, materials, and other resources comprising (i) Resource flows (e.g., energy), (ii) Technologies for resource use and energy conversion (e.g., vehicles and their engines), and (iii) Social/organisational forms of service delivery (e.g., publicly owned companies, or privately owned companies, e-commerce)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Service provisioning"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

