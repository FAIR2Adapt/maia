<http://connectivity-hub.com/terms/426b579e-8231-4e9d-92c0-d74a16ddddaa>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Very short-lived halogenated substances (VSLSs) are considered to include source gases (very short-lived halogenated substances present in the atmosphere in the form they were emitted from natural and anthropogenic sources), halogenated product gases arising from source gas degradation, and other sources of tropospheric inorganic halogens. VSLSs have tropospheric lifetimes of around 0.5 years or less."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Very short-lived halogenated substances (VSLSs)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

