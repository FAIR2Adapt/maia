        rdf:type           skos:Concept;
        dc:created         "2024-11-08T15:05:39.86Z"^^xsd:dateTime;
        dc:modified        "2025-01-03T09:53:27.874Z"^^xsd:dateTime;
        skos:altLabel      "hazard prediction"@en;
        skos:definition    "Hazard forecasts provide information on the physical event characteristics, such as the location, timing, and magnitude of a potentially damaging event (Merz et al., 2020 in Gill et al., 2022)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Hazard forecast"@en;
        skos:related       <http://connectivity-hub.com/terms/88da33d8-1177-4d22-b538-7d6fe7730beb> , <http://connectivity-hub.com/terms/41db08c9-fb69-4ee7-83ab-c9b930c6dc7c> , <http://connectivity-hub.com/terms/2605af32-4fdf-4847-ae26-4dcac5d01622>;
