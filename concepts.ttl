<http://connectivity-hub.com/terms/7c28c802-1af3-42e3-b5b7-d325c1d3b7ee>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The release of greenhouse gases that occur during the exploration, processing and delivery of fossil fuels to the point of final use. This excludes greenhouse gas emissions from fuel combustion for the production of useful heat or power. It encompasses venting, flaring, and leaks."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Fugitive emissions (oil and natural gas systems)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

