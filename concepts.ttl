<http://connectivity-hub.com/terms/3710567c-b7de-4e87-95bb-2d2b53b8d69c>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Qualitative descriptions of plausible future world evolutions, describing the characteristics, general logic and developments underlying a particular quantitative set of scenarios. Narratives are also referred to in the literature as “storylines” (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Narrative"@en;
        skos:related        <http://connectivity-hub.com/terms/d0984be9-c8ba-44ac-a05b-049a917b75b2>;
        skos:scopeNote      "As stated in the IPCC's definition, the term 'narrative' is often used interchangeably with the term 'storyline'. For example, Gill et al. (2022) define 'narrative' as that often used by social scientists to characterise peoples’ views, understandings or perspectives - aligning with the IPCC's definition of 'storyline'."@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       4 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
PREFIX dc:      <http://purl.org/dc/terms/>
PREFIX dct:     <http://purl.org/dc/terms/>
