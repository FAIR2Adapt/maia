<http://connectivity-hub.com/terms/d57fd815-3f0d-40d1-8b95-fd4d9864dfc2>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The permanent or semi-permanent move by a person for at least 1 year and involving crossing an administrative, but not necessarily a national, border."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Human mobility"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

