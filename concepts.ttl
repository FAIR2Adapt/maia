<http://connectivity-hub.com/terms/42a6bae6-54ab-42c8-8b31-2687775ed2fa>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Ethics involves questions of justice and value. Justice is concerned with right and wrong, equity and fairness, and, in general, with the rights to which people and living beings are entitled. Value is a matter of worth, benefit or good."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Ethics"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

