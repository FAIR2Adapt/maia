<http://connectivity-hub.com/terms/c0c36957-d8b4-4877-9a56-8c67cb800fca>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/6a172e46-96b1-48fa-8eec-b42aea759457>;
        skos:definition     "A common framework for describing and assessing risk across all three [IPCC] Working Groups is adopted to promote clear and consistent communication of risks and to better inform risk assessment and decision-making related to climate change (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Risk framework"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       3 .

