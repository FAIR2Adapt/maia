<http://connectivity-hub.com/terms/9910a20b-5c01-4c21-a210-c778d7dc40a7>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Peatlands are wetland ecosystems where soils are dominated by peat. In peatlands, net primary production exceeds organic matter decomposition as a result of waterlogged conditions, which leads to the accumulation of peat."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Peatlands"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

