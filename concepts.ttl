<http://connectivity-hub.com/terms/95d94271-df03-47d0-8361-5a6edb1db6c2>
        rdf:type           skos:Concept;
        dc:created         "2025-06-03T13:00:33.007Z"^^xsd:dateTime;
        dc:modified        "2025-06-03T13:05:01.049Z"^^xsd:dateTime;
        skos:definition    "Social Cost Benefit Analysis quantifies in monetary terms the effects on social welfare. Costs to society are given a negative value and benefits to society a positive value (HM Treasury, 2022)."@en;
        skos:historyNote   "https://assets.publishing.service.gov.uk/media/6645c709bd01f5ed32793cbc/Green_Book_2022__updated_links_.pdf"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Social cost benefit analysis"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      4 .

