<http://connectivity-hub.com/terms/1ad14362-9106-4736-9eb3-26ac8e9a6881>
        rdf:type           skos:Concept;
        dc:created         "2024-11-28T14:08:00.563Z"^^xsd:dateTime;
        dc:modified        "2025-06-05T15:05:21.808Z"^^xsd:dateTime;
        skos:altLabel      "preparedness and response"@en , "preparedness"@en;
        skos:definition    "The knowledge and capacities developed by governments, response and recovery organizations, communities, and individuals to effectively anticipate, respond to, and recover from the impacts of likely, imminent, or current disasters (UNDRR, 2016 in Gill et al., 2022)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Preparedness"@en;
        skos:related       <http://connectivity-hub.com/terms/d1f008d9-79aa-4ebe-90ac-7d72a69c0b66> , <http://connectivity-hub.com/terms/320a62d8-39d8-4d78-ab86-ef127aec8ee9>;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      7 .

