<http://connectivity-hub.com/terms/9c19692d-9841-4dce-ad59-0b8d620fd2a3>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Free-floating organisms living in the upper layers of aquatic systems. Their distribution and migration are primarily determined by water currents. A distinction is made between phytoplankton, which depend on photosynthesis for their energy supply, and zooplankton, which feed on phytoplankton, other zooplankton and bacterioplankton."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Plankton"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

