<http://connectivity-hub.com/terms/ed228ad1-f552-4b07-9196-70eef34f9423>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "An ozonesonde is a radiosonde measuring ozone (O3) concentrations. The radiosonde is usually carried on a weather balloon and transmits measured quantities by radio to a ground-based receiver."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Ozonesonde"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

