<http://connectivity-hub.com/terms/33358b63-3ecc-4a59-b30f-865f83e078a6>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The rate of change of an atmospheric variable, usually temperature, with height. The lapse rate is considered positive when the variable decreases with height."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Lapse rate"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

