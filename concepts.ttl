<http://connectivity-hub.com/terms/56702180-46ff-42a9-8932-fae079812328>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A type of greenhouse gas (GHG), HFCs are organic compounds that contain fluorine, carbon and hydrogen atoms and they are produced commercially as a substitute for chlorofluorocarbons (CFCs). They are mainly used in refrigeration and semiconductor manufacturing."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Hydrofluorocarbons (HFCs)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

