<http://connectivity-hub.com/terms/99ec2ddc-91e4-464a-a269-37eb713309c8>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A class of risk that can be defined as low-likelihood but well-understood events and events that cannot be predicted with current understanding (see Section 1.4.4.3 in AR6 WGI Chapter 1)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Surprises"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

