<http://connectivity-hub.com/terms/aac8991d-e361-4807-b570-885acd907f8d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "In this identity, global emissions are equal to the population size, multiplied by per capita output (gross world product), multiplied by the energy intensity of production, multiplied by the carbon intensity of energy."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Kaya identity"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

