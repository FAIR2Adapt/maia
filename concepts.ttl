<http://connectivity-hub.com/terms/b64a5713-f465-46f2-ad86-986e92d368b3>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Microscopic (2–200 μm) unicellular photosynthetic algae that live in surface waters of lakes, rivers and oceans and form shells of opal. In the global ocean, marine diatom species distribution is primarily driven by nutrient availability. On regional scales, their species distribution in ocean sediment cores can be related to past sea surface temperatures (Abrantes et al., 2013)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Diatoms"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

