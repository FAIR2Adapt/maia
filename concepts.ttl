<http://connectivity-hub.com/terms/523f02b8-c7a3-4dd6-b85c-3dfd45ae855e>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The interconnected body of saline water that covers 71% of the Earth’s surface, contains 97% of the Earth’s water and provides 99% of the Earth’s biologically habitable space. It includes the Arctic, Atlantic, Indian, Pacific and Southern Oceans, as well as their marginal seas and coastal waters."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Ocean"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

