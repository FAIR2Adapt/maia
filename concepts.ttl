<http://connectivity-hub.com/terms/3f88490f-4569-46ef-993e-c45a66ec76a9>
        rdf:type           skos:Concept;
        dc:created         "2025-06-03T13:07:28.888Z"^^xsd:dateTime;
        dc:modified        "2025-06-03T13:09:41.677Z"^^xsd:dateTime;
        skos:altLabel      "inclusiveness"@en , "inclusivity"@en;
        skos:definition    "Inclusion means creating an environment where everyone feels welcome and valued. An inclusive environment can only be created once we are more aware of our unconscious biases, and have learned how to manage them (LUNZ Hub, no date)."@en;
        skos:historyNote   "https://lunzhub.com/glossary/#I"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:narrower      <http://connectivity-hub.com/terms/6460d3d1-1238-4a1a-b51b-292aaa67ad44>;
        skos:prefLabel     "Inclusion"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      7 .

