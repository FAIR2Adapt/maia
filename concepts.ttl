<http://connectivity-hub.com/terms/a5a45a3b-16f4-4ea6-9e16-48ac8d15bd9b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The atmospheric layer adjacent to the Earth’s surface that is affected by friction against that boundary surface, and possibly by transport of heat and other variables across that surface (AMS, 2021). The lowest 100 m of the boundary layer (about 10% of the boundary layer thickness), where mechanical generation of turbulence is dominant, is called the surface boundary layer or surface layer."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Atmospheric boundary layer"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

