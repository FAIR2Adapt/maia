<http://connectivity-hub.com/terms/576ab090-1f71-4c5d-b678-45ca9a34e1b6>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The net present value of climate damages (with harmful damages expressed as a positive number) from one more tonne of carbon in the form of carbon dioxide (CO2), conditional on a global emissions trajectory over time."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Social cost of carbon"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

