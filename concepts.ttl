<http://connectivity-hub.com/terms/5803d73a-7897-46b3-bea2-db867382a888>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A critical threshold beyond which a system reorganises, often abruptly and/or irreversibly (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Tipping point"@en;
        skos:related        <http://connectivity-hub.com/terms/4f90f73f-6705-4f0a-b717-233dfc1f08c6> , <http://connectivity-hub.com/terms/b0097e5c-a7f6-4eac-b087-a665df810256> , <http://connectivity-hub.com/terms/430c45ee-88dc-4671-aa12-bc4af32d6c6a>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       7 .

