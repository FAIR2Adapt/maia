<http://connectivity-hub.com/terms/771539cb-f73e-4295-8062-80d92da36958>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Polar amplification describes the phenomenon where surface temperature change at high latitudes exceeds the global average surface temperature change. The terms Arctic amplification or Antarctic amplification are used when describing the phenomenon occurring at one of the poles."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Polar amplification"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

