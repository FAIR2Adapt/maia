<http://connectivity-hub.com/terms/37750c7a-0728-47e9-9a3c-0382b490f252>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The designed and built set of physical systems and corresponding institutional arrangements that mediate between people, their communities and the broader environment to provide services that support economic growth, health, quality of life and safety (Chester, 2019; Dawson et al., 2018)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/6fdef52d-9d70-4e11-9ae0-46780a4365a8> , <http://connectivity-hub.com/terms/539bb567-bdeb-428f-905d-4f96b6703077> , <http://connectivity-hub.com/terms/7d7d4b8a-1c87-4f1f-9337-07ed746a30dd> , <http://connectivity-hub.com/terms/e028c2ce-be07-4051-b846-cbe2b2416725>;
        skos:prefLabel      "Infrastructure"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

