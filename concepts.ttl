<http://connectivity-hub.com/terms/d63d7de0-78ee-4dcd-a6c3-6840dc666824>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The portion of the technical potential for which the social benefits exceed the social costs, taking into account a social discount rate and the value of externalities."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Economic potential"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

