<http://connectivity-hub.com/terms/8673572b-60c1-49b2-9284-f9dfffa0fcc4>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The third and current geological Era, which began 66.0 Ma. It comprises the Paleogene, Neogene and Quaternary Periods."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Cenozoic Era"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

