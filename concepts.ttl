<http://connectivity-hub.com/terms/1a8c0b6d-81a5-4fcf-8ff4-134ac8427cdd>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Snow that has survived at least one ablation season but has not been transformed to glacier ice. Its pore space is at least partially interconnected, allowing air and water to circulate. Firn densities typically are 400–830 kg m–3."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Firn"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

