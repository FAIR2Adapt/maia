<http://connectivity-hub.com/terms/37a81dc6-0a84-4606-9599-52bc7cc94aaf>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A climate refugium is a geographic area that has had a stable climate on evolutionary time scales, or that is projected to have a stable climate into the future."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Climate refugium"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

