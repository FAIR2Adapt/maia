<http://connectivity-hub.com/terms/a2b0f22a-3dea-4e49-ab30-d2d8847bb453>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Characteristic of many regions where mountains are located, in which past and/or future surface air temperature changes vary neither uniformly nor linearly with elevation. In many cases, warming is enhanced within or above a certain elevation range."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Elevation-dependent warming (EDW)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

