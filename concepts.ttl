<http://connectivity-hub.com/terms/aa6949c5-e408-4f60-9459-5faf5a312f2c>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Concentric rings of secondary wood evident in a cross section of the stem of a woody plant. The difference between the dense, small-celled late wood of one season and the wide-celled early wood of the following spring enables the age of a tree to be estimated, and the ring widths or density can be related to climate parameters such as temperature and precipitation."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Tree rings"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
PREFIX dc:      <http://purl.org/dc/terms/>
PREFIX dct:     <http://purl.org/dc/terms/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dme:     <https://grafsync.graphifi.com/schema/dm-entitlement/>
