<http://connectivity-hub.com/terms/3a0e19b2-4fb2-4045-9dc8-67c6c2035fb3>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A condition in which a household is unable to guarantee a certain level of consumption of domestic energy services (especially heating) or suffers disproportionate expenditure burdens to meet these needs."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Fuel poverty"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

