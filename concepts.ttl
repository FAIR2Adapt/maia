<http://connectivity-hub.com/terms/3e1a48da-3ffe-43be-b94f-a0ff522ab945>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The conversion of an element from its organic form to an inorganic form as a result of microbial decomposition. In nitrogen mineralization, organic nitrogen from decaying plant and animal residues (proteins, nucleic acids, amino sugars and urea) is converted to ammonia (NH3) and ammonium (NH4+) by biological activity."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Mineralization/Remineralization"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

