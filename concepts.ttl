<http://connectivity-hub.com/terms/bfe1bf4b-e863-49c8-98f0-c2e24861a215>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A set of minimal material requirements essential for achieving basic human well-being including nutrition, shelter, basic living conditions, clothing, healthcare, education, and mobility (Rao and Baer 2012; Rao and Min 2018; O’Neill et al. 2018)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Decent Living Standard"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

