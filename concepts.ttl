<http://connectivity-hub.com/terms/6c2ea3b9-4331-423a-96cb-2aca3fd1a65c>
        rdf:type           skos:Concept;
        dc:created         "2024-11-29T15:28:59.512Z"^^xsd:dateTime;
        dc:modified        "2025-06-05T14:47:19.151Z"^^xsd:dateTime;
        skos:definition    "An iterative and collaborative processes involving diverse types of expertise, knowledge and actors to produce context-specific knowledge and pathways towards a sustainable future (Norström et al., 2020 in Gill et al. 2022)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Knowledge co-production"@en;
        skos:related       <http://connectivity-hub.com/terms/9f5dddd8-5c6e-4e91-b09d-2404f9b82147> , <http://connectivity-hub.com/terms/f9ac95da-a8eb-40b4-b19c-cbbb16091359> , <http://connectivity-hub.com/terms/5770d7e9-d56b-48cf-b31b-eb559b92265a> , <http://connectivity-hub.com/terms/44252c8a-e8d0-40dd-9836-2c18cf9e11a9>;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      8 .

