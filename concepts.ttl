<http://connectivity-hub.com/terms/1e2b3afa-7fee-42e7-a99a-937a79ad1303>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Organic gas-phase compounds emitted from terrestrial and aquatic ecosystems that are critical in ecology and plant physiology, from abiotic and biotic stress functions to integrated components of metabolism. BVOCs are important in atmospheric chemistry as precursors for ozone (O3) and secondary organic aerosol formation. Other terms used to represent BVOCs are hydrocarbons (HCs), reactive organic gases (ROGs) and non-methane volatile organic compounds (NMVOCs)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Biogenic volatile organic compounds (BVOCs)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

