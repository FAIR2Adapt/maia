<http://connectivity-hub.com/terms/1f1836d6-8bfc-4e95-90d7-a8914f50a190>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Land and/or ocean area characterised by specific geographical and/or climatological features. The climate of a region emerges from a multi-scale combination of its own features, remote influences from other regions, and global climate conditions."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Region"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

