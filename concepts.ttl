<http://connectivity-hub.com/terms/42d6354a-ea19-4f3b-8b9f-967e4047f063>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Refers to a range of radiation modification measures not related to greenhouse gas (GHG) mitigation that seek to limit global warming. Most methods involve reducing the amount of incoming solar radiation reaching the surface, but others also act on the longwave radiation budget by reducing optical thickness and cloud lifetime."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/3308ec56-9c98-4615-8b5d-75cceab168bb> , <http://connectivity-hub.com/terms/cc39d429-84df-4c2b-bbb4-fc91e4d98d40> , <http://connectivity-hub.com/terms/70637a4e-d25e-4e84-9143-913e7b863b81>;
        skos:prefLabel      "Solar radiation modification (SRM)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

