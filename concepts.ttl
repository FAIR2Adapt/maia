<http://connectivity-hub.com/terms/789a6460-d2fd-4443-b10d-7b36d8c0f41b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Events and trends, often not climate-related, that have an important effect on the system exposed and can increase vulnerability to climate-related risk."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Stressors"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

