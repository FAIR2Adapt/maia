<http://connectivity-hub.com/terms/e1176f64-6580-4e76-bd51-f8604b1c0af5>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Reduction of friction at the base of an ice sheet or glacier due to lubrication by meltwater. This can allow the glacier or ice sheet to slide over its base. Meltwater may be produced by pressure-induced melting, friction or geothermal heat, or surface melt may drain to the base through holes in the ice."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Basal lubrication"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

