<http://connectivity-hub.com/terms/d6da3c78-68bf-4675-ba52-b7ca92add8d0>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The application of Carbon Dioxide Capture and Storage (CCS) technology to bioenergy conversion processes. Depending on the total life cycle emissions, including total marginal consequential effects (from indirect land use change (iLUC) and other processes), BECCS has the potential for net carbon dioxide (CO2) removal from the atmosphere."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Bioenergy and Carbon Dioxide Capture and Storage (BECCS)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

