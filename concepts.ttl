<http://connectivity-hub.com/terms/cb35fa0b-5830-4617-b2f3-00c3578a094f>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Days where maximum temperature, or nights where minimum temperature, falls below the 10th percentile, where the respective temperature distributions are generally defined with respect to the 1961-1990 reference period. For the corresponding indices, see Box 2.4."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Cold days/cold nights"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

