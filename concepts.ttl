<http://connectivity-hub.com/terms/c5caa0c2-8c9b-4af9-983d-4ebf02b45d44>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Policies and programmes for influencing how a certain demand for goods and/or services is met. In the energy sector, supply-side mitigation measures aim at reducing the amount of greenhouse gas emissions emitted per unit of energy service produced."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Supply-side measures"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

