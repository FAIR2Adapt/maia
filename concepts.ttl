<http://connectivity-hub.com/terms/3045a24a-43fc-46b3-abdc-f89c8eec1599>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Estimated global average of near-surface air temperatures over land and sea ice, and sea surface temperature (SST) over ice-free ocean regions, with changes normally expressed as departures from a value over a specified reference period."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Global mean surface temperature (GMST)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

