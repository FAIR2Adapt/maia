<http://connectivity-hub.com/terms/f84466b8-25f6-45b3-a95f-9e1763d1aef9>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Material resulting from charring of biomass, usually retaining some of the microscopic texture typical of plant tissues; chemically it consists mainly of carbon with a disturbed graphitic structure, with lesser amounts of oxygen and hydrogen."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Charcoal"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

