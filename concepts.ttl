<http://connectivity-hub.com/terms/4f90f73f-6705-4f0a-b717-233dfc1f08c6>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A large-scale abrupt change in the climate system that takes place over a few decades or less, persists (or is anticipated to persist) for at least a few decades and causes substantial impacts in human and/or natural systems (IPCC AR5, 2014)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Abrupt climate change"@en;
        skos:related        <http://connectivity-hub.com/terms/5803d73a-7897-46b3-bea2-db867382a888>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       3 .

