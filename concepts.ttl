<http://connectivity-hub.com/terms/f5f7057e-1e7e-4e6d-b0ef-3e2f94950941>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Improvement of the representation of some climatic aspects by one methodology compared to another methodology. For instance, downscaling a coarse resolution global climate model may improve the representation of regional climate in complex terrain (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Added value"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

