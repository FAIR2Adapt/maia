<http://connectivity-hub.com/terms/307f0e37-e17d-487c-99ca-573ae3a99656>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Exceedance of a specified global warming level, followed by a decline to or below that level during a specified period of time (e.g., before 2100). Sometimes the magnitude and likelihood of the overshoot is also characterised. The overshoot duration can vary from one pathway to the next, but in most overshoot pathways in the literature and as referred to as overshoot pathways in the AR6, the overshoot occurs over a period of at least one decade and up to several decades."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Temperature overshoot"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

