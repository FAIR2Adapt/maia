<http://connectivity-hub.com/terms/4e0a8903-0a07-4804-a4b6-919a30f40c52>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A layer in the oceanic water column in which salinity changes rapidly with depth. Generally, saltier water is denser and lies below less salty water. In some high-latitude oceans the surface waters may be colder than the deep waters, and the halocline is responsible for maintaining water column stability and isolating the surface waters from the deep waters."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Halocline"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

