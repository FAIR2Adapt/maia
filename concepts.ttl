<http://connectivity-hub.com/terms/4cc13c2f-3514-4a62-990a-fdb8faf22c11>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Numerical models that are that are of high enough resolution and have the necessary physics to represent the dynamical and physical processes of cloud formation."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Cloud-resolving models (CRMs)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

