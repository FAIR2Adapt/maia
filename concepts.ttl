        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Development that meets the needs of the present without compromising the ability of future generations to meet their own needs (WCED, 1987) and balances social, economic and environmental concerns (IPCC AR6, 2023)."@en;
