<http://connectivity-hub.com/terms/64b057c6-963c-4ec8-9ece-a4fa7516e83f>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The inherent, long-term potential of the land to sustainably generate ecosystem services, which reflects the capacity and resilience of the land-based natural capital, in the face of ongoing environmental change (UNEP, 2016)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Land potential"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

