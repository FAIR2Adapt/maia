<http://connectivity-hub.com/terms/13eff5ce-ee1d-48d1-8710-2efeb785dff9>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Wavelength, frequency or energy range of all electromagnetic radiation. In terms of solar radiation, the spectral irradiance is the power arriving at the Earth per unit area, per unit wavelength."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Electromagnetic spectrum"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

