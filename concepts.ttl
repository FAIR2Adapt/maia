<http://connectivity-hub.com/terms/93760f9d-6a41-44c5-9987-95011edb9aa8>
        rdf:type            skos:Concept;
        dc:modified         "2025-05-28T14:35:36.169Z"^^xsd:dateTime;
        skos:definition     "Information about the past, current or future state of the climate system that is relevant for mitigation, adaptation and risk management. It may be tailored or “co‑produced“ for specific contexts, taking into account users’ needs and values."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Climate information"@en;
        skos:related        <http://connectivity-hub.com/terms/ba00e68b-0e44-4705-b76c-d2635df35433>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

