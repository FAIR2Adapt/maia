<http://connectivity-hub.com/terms/f7784518-9c13-41db-b343-4284972b8eaf>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "In this report, shifting development pathways describes transitions aimed at re-directing existing developmental trends. Societies may put in place enabling conditions to influence their future development pathways, when they endeavour to achieve certain outcomes. Some outcomes may be common, while others may be context-specific, given different starting points."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Shifting development pathways (SDP)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

