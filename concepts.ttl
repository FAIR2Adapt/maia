<http://connectivity-hub.com/terms/2ad3df13-0f8c-4d2d-9429-702abf63b64b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A movement (a flow) of matter (e.g., water vapour, particles), heat or energy from one place to another, or from one medium (e.g., land surface) to another (e.g., atmosphere)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Flux"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

