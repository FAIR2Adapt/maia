<http://connectivity-hub.com/terms/0a0317c6-fc36-443e-a65e-8e35ed1926c4>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "An atmospheric large-scale wave pattern featuring a sequence of tropospheric high and low pressure anomalies stretching from the subtropical west Pacific to the east coast of North America."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Pacific-North American (PNA) pattern"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
