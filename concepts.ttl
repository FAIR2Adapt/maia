<http://connectivity-hub.com/terms/a546fe96-7390-4cd6-9d48-e13a563257e2>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Chemical process by which a pure carbon dioxide (CO2) stream is produced by capturing CO2 from the ambient air."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Direct air capture (DAC)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

