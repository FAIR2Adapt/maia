<http://connectivity-hub.com/terms/3154ddc4-e661-4bb8-97af-7084491793a0>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/18785e0a-e448-4cd3-99e7-d316f055513d>;
        skos:definition     "Biological hazards are of organic origin or conveyed by biological vectors, including pathogenic microorganisms, toxins and bioactive substances (UNDRR, 2016 in Gill et al., 2022)."@en;
        skos:editorialNote  "source:UNDRR HIPS";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/cc713306-66e3-46d0-985b-f240f45980ff> , <http://connectivity-hub.com/terms/fdc93d5e-c5e8-46e3-a132-7a6f22d70128> , <http://connectivity-hub.com/terms/9e4d33d3-9df1-45c0-a177-8132612a9d1c> , <http://connectivity-hub.com/terms/94682bc2-2e2f-4205-afaa-08808e7b95d8> , <http://connectivity-hub.com/terms/09a440aa-d4ea-45b6-9c3a-5e2dcd250c14> , <http://connectivity-hub.com/terms/b053cd06-7594-45fd-98b0-8bff07ccc852>;
        skos:prefLabel      "Biological hazards"@en;
        skos:scopeNote      "Examples: bacteria, viruses or parasites, as well as venomous wildlife and insects, poisonous plants and mosquitoes carrying disease-causing agents (Gill et al., 2022)."@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       7 .

