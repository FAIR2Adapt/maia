<http://connectivity-hub.com/terms/95a7262d-434e-4131-901f-01a769639630>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Geologically abrupt global warming events of the past associated with disturbances of the carbon cycle and impacts on the biosphere."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Hyperthermal events"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

