<http://connectivity-hub.com/terms/293e1fe7-feb9-48c2-9ba2-509919048c96>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A brief period of regional climatic cooling during a glacial or interglacial interval, often characterized by transient glacial advances. Stadials are generally of short duration (hundreds to a few thousand years) compared to glacial or interglacial intervals (lasting many thousands to tens of thousands of years). One example of a regional stadial event is based on millennial scale cooling recorded by oxygen isotope ratios in Greenland ice cores, the so called “Greenland Stadials” (Johnsen et al., 1992)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Stadial or stade"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

