<http://connectivity-hub.com/terms/f2752b87-1755-4207-963d-28750edce8f3>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A way to quantify the radiative response of the climate system to a global surface temperature change induced by a radiative forcing. It is quantified as the change in net energy flux at the top of atmosphere for a given change in annual global surface temperature. It has units of W m-2 °C-1."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Climate feedback parameter"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

