<http://connectivity-hub.com/terms/9fb772ff-117d-4ed5-b976-8ab9a0797743>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A mathematical operation that aims to make monetary (or other) amounts received or expended at different times (years) comparable across time. If the discount rate is positive, future values are given less weight than those today. The choice of discount rate(s) is debated as it is a judgement based on hidden and/or explicit values."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Discounting"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

