<http://connectivity-hub.com/terms/41b79825-cce5-4302-b1f6-3189d291ad92>
        rdf:type           skos:Concept;
        dc:created         "2025-06-05T16:07:13.188Z"^^xsd:dateTime;
        dc:modified        "2025-06-05T16:07:52.795Z"^^xsd:dateTime;
        skos:altLabel      "mixed-method"@en , "mixed methods"@en , "mixed methods approach"@en , "mixed-methods approach"@en , "mixed method"@en;
        skos:definition    "A research strategy that combines qualitative and quantitative data collection and/or analysis (UNICEF, 2014)."@en;
        skos:historyNote   "https://www.unicef.cn/media/25521/file/Annex_2_-_2022_UNICEF_Booklet_for_RSE_EN.pdf"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Mixed-method approach"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
