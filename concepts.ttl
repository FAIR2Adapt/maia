<http://connectivity-hub.com/terms/b307e7c5-054f-42e3-8697-8ea7d786a49a>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "An attempt to reduce the uncertainty in climate projections, using an ensemble of Earth system models (ESMs) to relate a specific feedback or future change to an observation of the past or current climate (typically some trend, variability or change in variability)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Emergent constraint"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

