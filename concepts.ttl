<http://connectivity-hub.com/terms/fea7d9c0-13c5-4b06-974c-74152d879cfc>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Transport of water or air along with its properties (e.g., temperature, chemical tracers) by winds or currents. Regarding the general distinction between advection and convection, the former describes transport by large-scale motions of the atmosphere or ocean, while convection describes the predominantly vertical, locally induced motions (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Advection"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

