<http://connectivity-hub.com/terms/6dc6a5ac-0d49-460e-9236-7bc0765680e4>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A mechanism of irreversible (on the decadal to centennial time scale) retreat of a grounding line for the marine-terminating glaciers, in case the glacier bed slopes towards the ice sheet interior."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Marine ice sheet instability (MISI)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

