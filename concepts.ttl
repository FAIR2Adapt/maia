<http://connectivity-hub.com/terms/ab28c1de-24b7-41f3-af5d-657f732662e4>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The point at which an actor's objectives (or system needs) cannot be secured from intolerable risks through adaptive actions (IPCC AR5, 2014)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Adaptation limit"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       3 .

