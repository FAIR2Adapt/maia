<http://connectivity-hub.com/terms/7969eb02-b3cb-40f2-bb0d-2a112908515d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Emissions of greenhouse gases (GHGs) (in particular carbon dioxide (CO2)), other trace gases and aerosols resulting from the combustion of fuels from fossil carbon deposits such as oil, gas and coal."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Fossil fuel emissions"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

