<http://connectivity-hub.com/terms/ff613300-2f1f-4444-8ff2-06f1131316fb>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A climate modelling activity from the World Climate Research Programme (WCRP) which coordinates and archives climate model simulations based on shared model inputs by modelling groups from around the world. The (CMIP3) multi-model data set includes projections using Special Report on Emissions Scenarios (SRES) scenarios. The (CMIP5) data set includes projections using the Representative Concentration Pathways (RCP). The CMIP6 phase involves a suite of common model experiments as well as an ensemble of CMIP-endorsed Model Intercomparison Projects (MIPs)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Coupled Model Intercomparison Project (CMIP)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

