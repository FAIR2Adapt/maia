<http://connectivity-hub.com/terms/f01c3901-8ffc-4cf1-b6d3-444dd9b4946d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Costs carried by individuals, companies or other private entities that undertake an action, whereas social costs include additionally the external costs on the environment and on society as a whole. Quantitative estimates of both private and social costs may be incomplete, because of difficulties in measuring all relevant effects."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Private costs"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

