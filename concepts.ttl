<http://connectivity-hub.com/terms/46b763a9-25bd-405a-afd3-cf9f01dc2306>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A metric characterising the vulnerability of a system. A climate vulnerability index is typically derived by combining, with or without weighting, several indicators assumed to represent vulnerability."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Vulnerability index"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

