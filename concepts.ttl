<http://connectivity-hub.com/terms/34c3be90-4d44-4dde-beba-ff5f5327a9f4>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Basin-scale ocean horizontal circulation pattern with slow flow circulating around the ocean basin, closed by a strong and narrow (100 to 200 km wide) boundary current on the western side. The subtropical gyres in each ocean are associated with high pressure in the centre of the gyres; the subpolar gyres are associated with low pressure."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Gyre"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

