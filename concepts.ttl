<http://connectivity-hub.com/terms/e9502433-d7c3-4459-8f71-cb512bd68567>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A climate feedback involving changes in the Earth’s surface albedo. Snow and ice have an albedo much higher (up to ~0.8) than the average planetary albedo (~0.3). With increasing temperatures, it is anticipated that snow and ice extent will decrease, the Earth’s overall albedo will decrease and more solar radiation will be absorbed, warming the Earth further."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Ice–albedo feedback"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

