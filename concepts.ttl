<http://connectivity-hub.com/terms/0dac020f-b5d0-45d0-9b87-783a7258dff6>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The component of the climate system comprising liquid surface and subterranean water, such as in oceans, seas, rivers, freshwater lakes, underground water, wetlands, etc."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Hydrosphere"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

