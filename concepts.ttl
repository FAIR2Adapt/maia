<http://connectivity-hub.com/terms/77ba0a53-a5d9-401b-8ec0-3a31147d5b90>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Surface mass balance refers to the difference between surface accumulation and surface ablation."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Surface mass balance (SMB)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

