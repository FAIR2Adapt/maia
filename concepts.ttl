<http://connectivity-hub.com/terms/376c5dd4-0618-435e-af24-f6a91fd3946c>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Deviations of climate variables from a given mean state (including the occurrence of extremes, etc.) at all spatial and temporal scales beyond that of individual weather events. Variability may be intrinsic, due to fluctuations of processesinternal to the climate system. "@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Internal climate variability"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

