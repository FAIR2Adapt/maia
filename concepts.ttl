<http://connectivity-hub.com/terms/200f9c9e-6fb3-4733-9e61-04e70eb5a3a5>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A positive effect that a policy or measure aimed at one objective has on another objective, thereby increasing the total benefit to society or the environment. Co-benefits are also referred to as ancillary benefits."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Co-benefits"@en;
        skos:related        <http://connectivity-hub.com/terms/7985e474-e2b6-419c-9147-3fca7707b23d>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

