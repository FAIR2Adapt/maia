<http://connectivity-hub.com/terms/e25214c9-dc89-4f86-80ae-58970db33dcf>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/a974d81d-48d5-4118-afa9-2d9bb94eb685>;
        skos:definition     "Justice that links development and human rights to achieve a human-centred approach to addressing climate change, safeguarding the rights of the most vulnerable people and sharing the burdens and benefits of climate change and its impacts equitably and fairly (MRFCJ, 2018)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Climate justice"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

