<http://connectivity-hub.com/terms/f24dff44-c8ce-4e49-bd0b-a46d0dc44140>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:altLabel       "Catastrophic building failure"@en;
        skos:definition     "Building collapse is the failure of load-bearing structural elements, causing a building to fall or fail catastrophically / catastrophic failure (adapted from US Department of Labor, no date). <br /> <p>US Department of Labor, no date. <a href=\"https://www.osha.gov/emergency-preparedness\">Structural Collapse Guide. Occupational Safety and Health Administration</a>. Accessed 30 October 2020.</p>"@en;
        skos:editorialNote  "source:UNDRR HIPS";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Building Collapse"@en;
        skos:scopeNote      "Progressive structural collapse is defined by the National Institute of Standards and Technology (NIST) as ‘the spread of an initial local failure in a manner analogous to a chain reaction that leads to partial or total collapse of a building’ (Ellingwood et al., 2007)."@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       4 .

