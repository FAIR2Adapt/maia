<http://connectivity-hub.com/terms/6776cc01-8e75-4b36-8d9f-341a9fe272e6>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Reducing greenhouse gas emissions by avoiding the use of an emissions-producing service entirely, shifting to the lowest-emission mode of providing the service, and/or improving the technologies and systems for providing the service in ways that reduce emissions."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Avoid, Shift, Improve (ASI)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

