<http://connectivity-hub.com/terms/82bc6887-a76c-40f8-b5da-79325bdfc1a8>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Adjustment of energy load characteristics by technical and/or non-technical change to balance energy demand and supply."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Flexibility (demand and supply)"@en;
