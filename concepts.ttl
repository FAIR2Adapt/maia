<http://connectivity-hub.com/terms/798510ca-c421-4da7-b119-5feab09133be>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The junction between a glacier or ice sheet and an ice shelf; the place where ice starts to float. This junction normally occurs over a zone, rather than at a line."@en;
