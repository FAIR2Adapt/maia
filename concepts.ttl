<http://connectivity-hub.com/terms/3c0c776d-45d0-4749-ac9b-e69bcd0b300c>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Water stored in the soil in liquid or frozen form. Root-zone soil moisture is of most relevance for plant activity."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Soil moisture"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

