<http://connectivity-hub.com/terms/261b2c51-8eac-4c75-ab44-c3ce617acf5a>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "An informal term for a geological period characterized by a long-term reduction in the temperature of the Earth’s climate, resulting in the presence or expansion of ice sheets and glaciers. Among the Earth’s ice ages is the current Quaternary Period, characterized by alternating glacial and interglacial intervals."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Ice age"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

