<http://connectivity-hub.com/terms/420e8401-d58e-4f5f-80ab-6c759f121b1b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/18785e0a-e448-4cd3-99e7-d316f055513d>;
        skos:definition     "Technological hazards originate from technological or industrial conditions, dangerous procedures, infrastructure failures or specific human activities (UNDRR, 2016 in Gill et al., 2022)."@en;
        skos:editorialNote  "source:UNDRR HIPS";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/09b9e15e-4ed2-4cbf-975a-96086dfb65a5> , <http://connectivity-hub.com/terms/cb5ea51e-68f4-4da9-a6d6-c6c8b6aa4ae3> , <http://connectivity-hub.com/terms/1af7e331-2680-41de-9082-ac46cd05f9de> , <http://connectivity-hub.com/terms/3916829b-caa0-486f-aa1c-4d01b98f4a32> , <http://connectivity-hub.com/terms/c58bdc83-e63e-430e-950f-7e2bad34fec2> , <http://connectivity-hub.com/terms/ab0619f8-2619-4fad-9415-14192191d94c>;
        skos:prefLabel      "Technological hazards"@en;
        skos:scopeNote      "Examples include industrial pollution, nuclear radiation, toxic wastes, dam failures, transport accidents, factory explosions, fires and chemical spills. Technological hazards also may arise directly as a result of the impacts of a natural hazard event (Gill et al., 2022)."@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       7 .

