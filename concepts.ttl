<http://connectivity-hub.com/terms/e2567a60-f383-4653-873d-e9f35728c4f4>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The persistent and positive (downward) net top of atmosphere energy flux associated with greenhouse gas forcing of the climate system."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Earth's energy imbalance"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

