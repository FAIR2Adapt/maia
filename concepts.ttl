<http://connectivity-hub.com/terms/1906d59f-f5a0-42bc-8ceb-a1c92ab7f1aa>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Forests subject to human interventions (notably silvicultural management such as planting, pruning, thinning), timber and fuelwood harvest, protection (fire suppression, insect suppression) and management for amenity values or conservation, with defined geographical boundaries (Ogle et al., 2018). [Note: For a discussion of the term ‘forest’ in the context of National GHG inventories, see the 2006 IPCC Guidelines for National GHG Inventories (IPCC 2006).]"@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Managed forest"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

