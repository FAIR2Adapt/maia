<http://connectivity-hub.com/terms/01a5fe22-65a0-4ac6-95fb-a79fa59746bd>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The surface level of the ocean at a particular point averaged over an extended period of time such as a month or year. Mean sea level is often used as a national datum to which heights on land are referred."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Mean sea level"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

