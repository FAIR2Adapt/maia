<http://connectivity-hub.com/terms/d0dbcf55-f5a7-481b-9057-148ddff2676e>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The organic component of soil, comprising plant and animal residue at various stages of decomposition, and soil organisms."@en;
