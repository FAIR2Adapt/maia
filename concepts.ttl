<http://connectivity-hub.com/terms/331f1b2a-ff11-4838-93f8-fb567ac82471>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Policies and programmes for influencing the demand for goods and/or services. In the energy sector, demand-side mitigation measures aim at reducing the amount of greenhouse gas emissions emitted per unit of energy service used."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Demand-side measures"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

