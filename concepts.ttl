        rdf:type           skos:Concept;
        dc:created         "2025-06-09T15:29:23.036Z"^^xsd:dateTime;
        dc:modified        "2025-06-09T15:30:38.417Z"^^xsd:dateTime;
        skos:altLabel      "digital twining"@en , "digital twin models"@en;
        skos:definition    "A digital twin is a virtual representation or digital replica of a physical object, system, or process. It integrates real-time data and simulations to mimic the behaviour, characteristics and dynamics of its physical counterpart (The European Space Agency, n.d)."@en;
        skos:historyNote   "European Space Agency Earth Observation Glossary https://www.esa.int/Applications/Observing_the_Earth/Earth_observation_glossary accesssed 09/06/2025"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Digital twin"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      7 .

