<http://connectivity-hub.com/terms/c17f01b7-3819-4eaa-b3f9-6f9bd4582e4d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The ability of a place to support human life by providing protection from hazards which challenge human survival, and by assuring adequate space, food and freshwater."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Habitability (human)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

