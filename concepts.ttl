<http://connectivity-hub.com/terms/0315f221-6235-4129-a348-29bf23812856>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Monetary assessment of all negative and positive impacts associated with a given action. Cost–benefit analysis enables comparison of different interventions, investments or strategies and reveals how a given investment or policy effort pays off for a particular person, company or country. Cost–benefit analyses representing society's point of view are important for climate change decision-making, but there are difficulties in aggregating costs and benefits across different actors and across timescales."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Cost–benefit analysis"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

