<http://connectivity-hub.com/terms/2c3a9b02-5908-4b93-b101-bd305dd7c67b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The average trough-to-crest height of the highest one-third of the wave heights (sea and swell) occurring in a particular time period."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Significant wave height"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

