<http://connectivity-hub.com/terms/b7cb1b36-9db0-4ee2-943d-a995607a761c>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Dark areas on the Sun where strong magnetic fields reduce the convection, causing a temperature reduction of about 1500 K compared to the surrounding regions. The number of sunspots is higher during periods of higher solar activity and varies in particular with the solar cycle."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Sunspots"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

