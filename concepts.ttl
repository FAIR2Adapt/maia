<http://connectivity-hub.com/terms/a373ab99-dd44-4de3-bd4f-d77277f25eba>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Relatively stable, carbon-rich material produced by heating biomass in an oxygen-limited environment. Biochar is distinguished from charcoal by its application: biochar is used as a soil amendment with the intention to improve soil functions and to reduce greenhouse gas emissions from biomass that would otherwise decompose rapidly (IBI, 2018)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Biochar"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

