<http://connectivity-hub.com/terms/6711212c-47ca-43c4-a534-7d7577de21bc>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime , "2024-10-04T10:59:27.803Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/79ae254f-fe72-4358-9722-73669c940f18>;
