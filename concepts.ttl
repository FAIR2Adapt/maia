<http://connectivity-hub.com/terms/82771ca3-058f-467c-84dc-5d8cd4f66ac1>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Water flow within a river channel, for example, expressed in m3 s–1. A synonym for river discharge."@en;
