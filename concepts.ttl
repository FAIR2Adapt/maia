<http://connectivity-hub.com/terms/c4fac386-3728-4dc1-8a32-1246bdb1bffa>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/787eeba7-1ce7-41f8-9509-4f0f567ad130>;
        skos:definition     "The difference between actually implemented adaptation and a societally set goal, determined largely by preferences related to tolerated climate change impacts and reflecting resource limitations and competing priorities (UNEP, 2014; UNEP, 2018 in IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Adaptation gap"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       3 .

