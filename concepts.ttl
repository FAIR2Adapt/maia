        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The effects of policies that result in a displacement of the environmental impact, thereby counteracting the intended effects of the initial policies."@en;
