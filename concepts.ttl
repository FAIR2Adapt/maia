<http://connectivity-hub.com/terms/8dc9032c-7874-4546-af4c-fdc61d7f18cc>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A process or set of processes whose evolution in time is governed by a set of deterministic physical laws. The climate system is a dynamical system."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Dynamical system"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

