<http://connectivity-hub.com/terms/86121493-7824-45b1-84e5-b08e7317ba00>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Measures of the success of a prediction against observationally based information. No single measure can summarize all aspects of forecast quality, and a suite of metrics is considered. Metrics will differ for forecasts given in deterministic and probabilistic form."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Prediction quality/skill"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

