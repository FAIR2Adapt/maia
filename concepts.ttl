<http://connectivity-hub.com/terms/1051631e-d9c1-45ed-9340-b33ee0f329dd>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The turbulent or conductive flux of heat from the Earth’s surface to the atmosphere that is not associated with phase changes of water; a component of the surface energy budget."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Sensible heat flux"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

