<http://connectivity-hub.com/terms/bbb0fb1c-bff1-4eb0-a5ca-db0938e7aed7>
        rdf:type            skos:Concept;
        dc:modified         "2025-06-05T15:05:51.116Z"^^xsd:dateTime;
        skos:definition     "Processes for designing, implementing and evaluating strategies, policies and measures to improve the understanding of current and future disaster risk, foster disaster risk reduction and transfer, and promote continuous improvement in disaster preparedness, prevention and protection, response and recovery practices, with the explicit purpose of increasing human security, well-being, quality of life and sustainable development (SD) (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Disaster risk management (DRM)"@en;
        skos:related        <http://connectivity-hub.com/terms/28b7c1f7-ae68-4e4a-81f1-6e66bf04fd12> , <http://connectivity-hub.com/terms/01042526-0e27-4345-904c-aa646e2260ae> , <http://connectivity-hub.com/terms/99596d76-6804-426b-b6fd-cbda6c842031> , <http://connectivity-hub.com/terms/8aef133f-b5f8-4d0f-b4d0-b66d864e9e95> , <http://connectivity-hub.com/terms/320a62d8-39d8-4d78-ab86-ef127aec8ee9> , <http://connectivity-hub.com/terms/7aea52fd-d2bf-45b9-91c2-2dbf2aab0bbb> , <http://connectivity-hub.com/terms/aef81e7e-0911-4d2a-bca1-a457d62730eb>;
        skos:scopeNote      "The application of disaster risk reduction policies and strategies can prevent new disaster risk, reduce existing disaster risk and manage residual risk, contributing to the strengthening of resilience and reduction of disaster losses (Adapted from: UNDRR, 2016 in Gill et al., 2022)."@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       11 .

