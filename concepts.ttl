<http://connectivity-hub.com/terms/c192b62e-dfed-4f32-af9a-3fc39aa84e3a>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Mechanisms put in place to respectively monitor and evaluate efforts to reduce greenhouse gas emissions and/or adapt to the impacts of climate change with the aim of systematically identifying, characterising and assessing progress over time."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Monitoring and evaluation (M&E)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

