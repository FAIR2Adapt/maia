<http://connectivity-hub.com/terms/be512645-dd38-4fc6-a39f-9c76165db1e6>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "In IPCC AR6, concepts used to synthesize the knowledge of climate change across not just the physical sciences, but also across impacts, adaptation, and mitigation research. The concept of ‘dimensions of integration’ includes (i) emission and concentration scenarios underlying the climate change projections assessed in this report, (ii) levels of projected global mean temperature change and (iii) total amounts of cumulative carbon emissions for projections."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Dimensions of integration"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

