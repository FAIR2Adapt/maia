<http://connectivity-hub.com/terms/4ee311cb-134d-4da1-b436-07442c7d142a>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Often used synonymously with ‘epidemic’, usually to indicate localised as opposed to generalised epidemics (WHO, 2020)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Outbreak"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

