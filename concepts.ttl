<http://connectivity-hub.com/terms/a00557a5-a148-4997-93ae-ba029e049d68>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A dynamical system such as the climate system, governed by non-linear deterministic equations, may exhibit erratic or chaotic behaviour in the sense that very small changes in the initial state of the system lead to large and apparently unpredictable changes in its temporal evolution. Such chaotic behaviour limits the predictability of the state of a non-linear dynamical system at specific future times, although changes in its statistics may still be predictable given changes in the system parameters or boundary conditions."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Chaotic"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

