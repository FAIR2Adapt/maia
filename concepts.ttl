<http://connectivity-hub.com/terms/697aebc7-7160-4bd3-a532-fe35f87a8ab1>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime , "2024-10-04T10:59:05.904Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/79ae254f-fe72-4358-9722-73669c940f18>;
        skos:definition     "The energy delivered to final users (firms, individuals, institutions), where it becomes usable energy in supplying energy services (e.g., light, heat, mobility)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Final energy"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

