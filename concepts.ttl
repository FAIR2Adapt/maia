<http://connectivity-hub.com/terms/5e8c0512-bd62-488a-bdbf-eecd38842997>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Water flow within a river channel, for example, expressed in m3s–1. A synonym for river streamflow."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "River discharge"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

