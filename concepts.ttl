<http://connectivity-hub.com/terms/98ba2cb8-e100-4541-b652-1d1381090eb3>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Carbon gain by photosynthesis per unit of water lost by evapotranspiration. It can be expressed on a short-term basis as the ratio of photosynthetic carbon gain per unit transpirational water loss, or on a seasonal basis as the ratio of net primary production or agricultural yield to the amount of water used."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Water-use efficiency"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

