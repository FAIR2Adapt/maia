<http://connectivity-hub.com/terms/be3d3b01-6d9e-4b26-aed4-c9160bbf0b19>
        rdf:type           skos:Concept;
        dc:created         "2024-12-09T09:48:50.005Z"^^xsd:dateTime;
        dc:modified        "2025-01-03T09:53:12.121Z"^^xsd:dateTime;
        skos:altLabel      "functions"@en;
        skos:definition    "A function can be defined in a mathematical sense, as an expression, rule, or law that defines a relationship between one variable (the independent variable) and another variable (the dependent variable). A function can be used to describe quantitative and qualitative relationships (Britannica, 2021 in Gill et al., 2022)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Function"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      5 .

