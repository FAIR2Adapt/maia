<http://connectivity-hub.com/terms/9015f338-87a2-4a90-abb9-88bb15343d93>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A pair of satellites that measured the Earth’s gravity field anomalies from 2002 to 2017. These fields have been used, among other things, to study mass changes of the polar ice sheets and glaciers."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Gravity Recovery and Climate Experiment (GRACE)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

