<http://connectivity-hub.com/terms/9c10ef9f-bade-4f93-a278-93652d0ddaf4>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Access to clean, reliable and affordable energy services for cooking and heating, lighting, communications and productive uses (with special reference to Sustainable Development Goal 7) (AGECC, 2010)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Energy access"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

