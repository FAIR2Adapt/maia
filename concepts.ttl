<http://connectivity-hub.com/terms/6ae18619-346b-45de-8a92-ca78b80804fc>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Places of concentrated human habitation. Settlements can range from isolated rural villages to urban regions with significant global influence. They can include formally planned and informal or illegal habitation and related infrastructure."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Settlements"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

