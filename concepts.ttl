<http://connectivity-hub.com/terms/ac87e19c-7e03-42d6-b249-283b280f9ec8>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A wind or current that is in balance with the horizontal pressure gradient and the Coriolis force, and thus is outside of the influence of friction. Thus, the wind or current is directly parallel to isobars and its speed is proportional to the horizontal pressure gradient."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Geostrophic winds or currents"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

