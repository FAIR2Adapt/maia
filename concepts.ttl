<http://connectivity-hub.com/terms/16ce33ec-4acc-4104-b567-9570de96c3b0>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Theoretical concepts and computational methods that represent and simulate the behaviour of real-world systems derived from a set of functional components and their interactions with each other and the system environment, through physical and mechanistic processes occurring over time."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Process-based model"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

