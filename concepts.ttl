<http://connectivity-hub.com/terms/b10b31a7-80b3-4a28-9019-7af17f6c49eb>
        rdf:type           skos:Concept;
        dc:created         "2025-06-05T15:46:02.782Z"^^xsd:dateTime;
        dc:modified        "2025-06-05T15:51:16.352Z"^^xsd:dateTime;
        skos:definition    "An approach to the analysis of qualitative data that aims to generate theory out of research data by achieving a close fit between the two. The ‘substantive’ grounded theory is applicable to the setting studied, whereas the ‘formal’ grounded theory typology is applicable to a range of similar settings (UNICEF, 2014)."@en;
        skos:historyNote   "https://www.unicef.cn/media/25521/file/Annex_2_-_2022_UNICEF_Booklet_for_RSE_EN.pdf"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Grounded theory"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      4 .

