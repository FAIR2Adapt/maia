<http://connectivity-hub.com/terms/bd6b6b51-65c9-4757-83ff-db3696d1bbf2>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/083e4731-556e-4012-810a-a961d2777362>;
        skos:definition     "A farming system that promotes minimum soil disturbance (e.g., by using no till practices), maintenance of a permanent soil cover and diversification of plant species. It aims to prevent land degradation and regenerate degraded lands by enhancing biodiversity and natural biological processes above and below the ground surface, that contribute to increased water and nutrient use efficiency and improved and sustained crop production (FAO, 2016)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Conservation agriculture"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

