<http://connectivity-hub.com/terms/e21fb59b-4e56-456a-a16f-8c4ca822bc69>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The set of public and private sector organisations (i.e., formally organised entities such as firms and universities; ‘actors’) and institutions, whose activities and interactions generate, modify and deploy new technologies. The SI approach has been used to understand and analyse innovation at the national, regional, and technological levels, and in transnational contexts (Lundvall, 1988, 1992)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Systems of Innovation (SI)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

