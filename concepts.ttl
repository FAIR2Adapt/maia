<http://connectivity-hub.com/terms/81327e40-ed5c-4d1c-8e15-5ce27e38244f>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Any process or activity which releases a greenhouse gas (GHG), an aerosol or a precursor of a GHG into the atmosphere (United Nations Framework Convention on Climate Change (UNFCCC) Article 1.9 (UNFCCC, 1992))."@en;
