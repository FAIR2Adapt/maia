<http://connectivity-hub.com/terms/71da780f-14c5-4311-8425-4a4ebdd24b63>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "General term collectively describing a variety of magnetic phenomena on the Sun such as sunspots, faculae (bright areas), and flares (emission of high-energy particles). It varies on time scales from minutes to millions of years. The solar cycle, with an average duration of 11 years, is an example of a quasi-regular change in solar activity."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Solar activity"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

