<http://connectivity-hub.com/terms/1e82b983-8590-486c-96ca-335c3f4b231a>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Conversion to forest of land that has previously contained forests but that has been converted to some other use.[Note: For a discussion of the term forest and related terms such as afforestation, reforestation and deforestation, see the 2006 IPCC Guidelines for National Greenhouse Gas Inventories and their 2019 Refinement, and information provided by the United Nations Framework Convention on Climate Change (IPCC, 2006, 2019; UNFCCC 2021a, b).]"@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Reforestation"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

