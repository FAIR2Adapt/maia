<http://connectivity-hub.com/terms/592ad627-6b49-48c8-8933-d354aa73c166>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The process of biologically precipitating calcium carbonate minerals to create organism shells, skeletons, otoliths, or other body structures. The chemical equation describing calcification is Ca2+(aq) + 2HCO3−(aq) → CaCO3(s) + CO2 + H2O. Aragonite and calcite are two common crystalline forms of biologically precipitated calcium carbonate minerals that have different solubilities."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Calcification"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

