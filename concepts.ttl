<http://connectivity-hub.com/terms/3eb866d1-69a8-4a85-9e1f-5b8fdcc6ffc9>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Conversion to forest of land that historically has not contained forests. [Note: For a discussion of the term forest and related terms such as afforestation, reforestation and deforestation, see the 2006 IPCC Guidelines for National Greenhouse Gas Inventories and their 2019 Refinement, and information provided by the United Nations Framework Convention on Climate Change (IPCC 2006, 2019; UNFCCC 2021a, b).]"@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Afforestation"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

