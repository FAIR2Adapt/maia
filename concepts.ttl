<http://connectivity-hub.com/terms/81b3f993-6eea-42c2-a501-17341c7cfeae>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A band of low-level convergence, cloudiness and precipitation ranging from the west Pacific warm pool south-eastwards towards French Polynesia. It is one of the most significant features of subtropical Southern Hemisphere climate. It shares some characteristics with the Inter-tropical Convergence Zone (ITCZ), but is more extratropical in nature, especially east of the International Date Line."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "South Pacific Convergence Zone (SPCZ)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

