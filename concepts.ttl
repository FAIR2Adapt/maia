<http://connectivity-hub.com/terms/696ed25a-9c0c-4527-8daf-ca93a149a110>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/083e4731-556e-4012-810a-a961d2777362>;
        skos:definition     "A universally agreed definition of this relatively new farming approach has yet to be established, but regenerative agriculture broadly refers to the implementation of varying combinations of agricultural management practices, to ensure the continued restoration and enhancement of soil health, biodiversity and ecosystem functioning, in conjunction with profitable agricultural production."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Regenerative agriculture"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

