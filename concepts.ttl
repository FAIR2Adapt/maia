<http://connectivity-hub.com/terms/6e4e00dc-af2d-4ea3-be02-9e3cc3cec7ae>
        rdf:type           skos:Concept;
        dc:created         "2025-06-06T14:41:10.697Z"^^xsd:dateTime;
        dc:modified        "2025-06-06T14:42:33.993Z"^^xsd:dateTime;
        skos:definition    "A transdisciplinary approach integrates different knowledge systems, or ways of knowing, beyond academia, such as practitioner knowledge, or local and indigenous knowledge (Chausson and Cole, 2020)."@en;
        skos:historyNote   "Chausson, A., & Cole, L. (2020, December 17). Talking transdisciplinarity. International Institute for Environment and Development. https://www.iied.org/talking-transdisciplinarity"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Transdisciplinary approach"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      5 .

