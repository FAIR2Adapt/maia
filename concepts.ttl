<http://connectivity-hub.com/terms/0d11ee1a-a84d-4869-8c81-c0cb40d9eb9e>
        rdf:type           skos:Concept;
        dc:created         "2024-12-23T09:33:39.991Z"^^xsd:dateTime;
        dc:modified        "2025-01-03T09:37:51.567Z"^^xsd:dateTime;
        skos:altLabel      "user"@en;
        skos:definition    "In general terms, a user is an individual, organisation or community who employs or uses a product, model, or service (Gill et al., 2022)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Users"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      4 .

