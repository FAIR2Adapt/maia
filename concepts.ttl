<http://connectivity-hub.com/terms/1433cd66-1be5-4504-a7c2-90003da60b31>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Rights that are inherent to all human beings, universal, inalienable, and indivisible, typically expressed and guaranteed by law. They include the right to life, economic, social, and cultural rights, and the right to development and self-determination (UNOHCHR, 2018)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Human rights"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

