<http://connectivity-hub.com/terms/afc0e85d-2835-4dde-ae25-b57380e9ca3d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Process by which characteristic landforms result from thawing of ice-rich permafrost or melting of massive ice (IPA, 2005)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Thermokarst"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

