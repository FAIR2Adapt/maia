<http://connectivity-hub.com/terms/c9568aae-54a1-4077-ac8c-30cab001eb34>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "EMICs represent climate processes at a lower resolution or in a simpler, more idealized fashion than an Earth system model (ESM)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Earth system model of intermediate complexity (EMIC)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

