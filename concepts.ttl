<http://connectivity-hub.com/terms/4fee4994-6432-409d-8c9c-f46b3a6d6dc5>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Any natural or human-induced factor that directly or indirectly causes a change in a system (adapted from MA, 2005)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/6a91e56f-a5b7-4b46-8f2c-a8a3fa8da7c3>;
