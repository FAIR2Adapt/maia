<http://connectivity-hub.com/terms/f374733f-5142-4119-b0e7-7e5b95837221>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "An interaction of aerosol directly with radiation produces radiative effects. In this report, two levels of radiative forcing (or effect) are distinguished: Effective radiative forcing (or effect) due to aerosol–radiation interactions (ERFari) and Instantaneous radiative forcing (or effect) due to aerosol–radiation interactions (IRFari) (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/844598c8-c1cc-4fe2-a33c-bb09703114b8>;
        skos:prefLabel      "Aerosol–radiation interaction"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

