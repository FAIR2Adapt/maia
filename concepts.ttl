<http://connectivity-hub.com/terms/2f2bf4de-7b28-49a6-a9a1-b3eb0ef0e9ef>
        rdf:type           skos:Concept;
        dc:created         "2025-06-05T14:27:19.397Z"^^xsd:dateTime;
        dc:modified        "2025-06-05T14:30:46.575Z"^^xsd:dateTime;
        skos:altLabel      "complex systems"@en , "complex system"@en;
        skos:definition    "Systems characterized by complex interactions, where unexpected outcomes are more likely to occur. They differ from linear systems in that they have tight spacing of equipment, many common-mode connections, limited options for substitution of supplies and materials, and unfamiliar or unintended feedback loops (Aall et al., 2020)."@en;
        skos:historyNote   "Aall, C., Leander, E., Menk, L., Meyer, M., Dale, B., Lückerath, D., Nyadzi, E., Rome, E., Rudolf, F., Goosen, H., André, K.,Harris, K., Becker, L., Fulco, L., Benzie, M., Zebisch, M., Hanssen Korsbrekke, M., Jansen, M.K., Durmaz, N., Kienberger, S., Terzi, S., Lehr, U. & Gerger Swartling, Å. (2020). Methods for climate change risk assessments: An international knowledge review. Vestlandsforskingsrapport 7/2020. Sogndal: Western Norway Research Institute. Retrieved from https://www.vestforsk.no/\nsites/default/files/2021-01/D1.1 knowledge%20review%20final2%20%281%29.pdf."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Complex systems"@en;
        skos:related       <http://connectivity-hub.com/terms/a602c114-c402-4b7e-98cd-a3055cac4985> , <http://connectivity-hub.com/terms/fc501a7b-2d4f-4f0a-8e6a-c0fb1d19437f>;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      7 .

