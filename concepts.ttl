<http://connectivity-hub.com/terms/cea8301a-b0eb-4be7-a6af-f7f84fd6ec6e>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The highest (or, alternatively, lowest) value of a given variable, on average occurring once in a given period of time (e.g., in 10 years)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Return value"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

