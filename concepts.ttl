<http://connectivity-hub.com/terms/cf011c44-30c8-4cf9-ad70-6f4fe0732d65>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The range or spread in results from climate models, such as those assembled for Coupled Model Intercomparison Project Phase 6 (CMIP6). Does not necessarily provide an exhaustive and formal estimate of the uncertainty in feedbacks, forcing or projections even when expressed numerically, for example, by computing a standard deviation of the models’ responses. In order to quantify uncertainty, information from observations, physical constraints and expert judgement must be combined, using a statistical framework."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Model spread"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

