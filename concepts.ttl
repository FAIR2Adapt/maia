<http://connectivity-hub.com/terms/99fc38a5-2399-4060-a2c8-5ff0255572dd>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The trajectory taken over time to meet different goals for greenhouse gas (GHG) emissions, atmospheric concentrations, or global mean surface temperature change that implies a set of economic, technological, and behavioural changes. This can encompass changes in the way energy and infrastructure is used and produced, natural resources are managed, institutions are set up, and in the pace and direction of technological change (TC)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Transformation pathway"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

