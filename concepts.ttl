<http://connectivity-hub.com/terms/f5deb21e-a2cb-4262-a195-4dcb97e40abb>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Elements of a classification framework, first developed in the IPCC Third Assessment Report, which aims to facilitate judgements about what level of climate change may be dangerous (in the language of Article 2 of the United Nations Framework Convention on Climate Change (UNFCCC) by aggregating risks from various sectors, considering hazards, exposures, vulnerabilities, capacities to adapt, and the resulting impacts."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Reasons for Concern (RFCs)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

