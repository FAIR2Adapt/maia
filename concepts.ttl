<http://connectivity-hub.com/terms/ef28d0a7-4a9a-44f7-8d9e-c2d9514103c0>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The disappearance of a species from an area, sometimes also referred to as local extinction. Its use implies that the species still occurs elsewhere."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Extirpation"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

