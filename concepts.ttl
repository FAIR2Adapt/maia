<http://connectivity-hub.com/terms/dbc90199-45c2-4ffb-a373-adfd40f49991>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The period of transition from glacial conditions at the end of a glacial period to interglacial conditions characterized by a reduction in land ice volume. Gradual changes can be punctuated by abrupt changes linked to stadial/interstadial events and bipolar seesaw aspect. The last deglacial transition occurred between about 18,000 and 11,000 years ago. It encompasses rapid events such as Meltwater Pulse 1A (MWP-1A) and millennial-scale fluctuations such as the Younger Dryas."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Deglacial or deglaciation or glacial termination"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

