<http://connectivity-hub.com/terms/e3f94dc6-0954-4dcc-be8c-71bb0fbed145>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Important class of organic chemical air pollutants that are volatile at ambient air conditions. Other terms used to represent VOCs are hydrocarbons (HCs), reactive organic gases (ROGs) and non-methane volatile organic compounds (NMVOCs). NMVOCs are major contributors (together with NOx and CO) to the formation of photochemical oxidants such as ozone."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Volatile Organic Compounds (VOC)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

