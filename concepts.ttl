<http://connectivity-hub.com/terms/69db0708-2c99-4d41-8fee-a5295cf5945d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Emissions released to the atmosphere for the production of goods and services by a certain entity (e.g., a person, firm, country, or region). "@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Production-based emissions"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

