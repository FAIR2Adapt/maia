<http://connectivity-hub.com/terms/8facf466-5268-48d2-a84c-5e6b66142406>
        rdf:type           skos:Concept;
        dc:created         "2025-06-06T14:36:07.774Z"^^xsd:dateTime;
        dc:modified        "2025-06-06T14:37:12.664Z"^^xsd:dateTime;
