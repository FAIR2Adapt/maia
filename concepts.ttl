<http://connectivity-hub.com/terms/a4bb0ee1-32f3-4f0c-a7d3-59b73d985335>
        rdf:type           skos:Concept;
        dc:created         "2025-06-09T15:04:16.215Z"^^xsd:dateTime;
        dc:modified        "2025-06-09T15:05:08.64Z"^^xsd:dateTime;
        skos:definition    "The records of observed climate conditions taken at specific sites and times with particular instruments under a set of standard procedures.\n\nA climate dataset therefore contains climate information at the observation sites, as well as other non-climate-related factors such as the environment of the observation station, and information about the instruments and observation procedures (Metadata) (WMO, 2020)."@en;
        skos:historyNote   "https://community.wmo.int/en/climate-data-homogenization"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Climate data"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      3 .

