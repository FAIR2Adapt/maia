<http://connectivity-hub.com/terms/294a6e6f-64a6-40ee-bcbc-97de03f86754>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The degree to which a system or species is affected, either adversely or beneficially, by climate variability or change. The effect may be direct (e.g., a change in crop yield in response to a change in the mean, range, or variability of temperature) or indirect (e.g., damages caused by an increase in the frequency of coastal flooding due to sea level rise) (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Sensitivity"@en;
        skos:related        <http://connectivity-hub.com/terms/cc387fcd-d403-41da-823b-169437ea4a5e>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       3 .

