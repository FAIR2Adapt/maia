<http://connectivity-hub.com/terms/bfbbaa23-5efc-413e-81a6-139a226217a9>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The ocean carbon cycle is the set of processes that exchange carbon between various pools within the ocean, as well as between the atmosphere, Earth’s interior, cryosphere, and the sea-floor."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Ocean carbon cycle"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

