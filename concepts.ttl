<http://connectivity-hub.com/terms/0e9c6bea-625a-4605-b3d2-df52cfcad370>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/75d4a0f7-7e99-4d9b-8f74-5ea748714d1f>;
        skos:definition     "Thaw is the melting of snow or ice at the Earth’s surface due to a temperature rise above 0°C (WMO, 1992). <br /> <p>WMO, 1992. <a href=\"https://library.wmo.int/doc_num.php?explnum_id=4712\">International Meteorological Vocabulary, WMO-No. 182. World Meteorological Organization (WMO)</a>. Accessed 13 October 2020.</p>"@en;
        skos:editorialNote  "source:UNDRR HIPS";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Thaw"@en;
        skos:scopeNote      "Additional definitions of thaw include: To melt a substance, ice for example, by warming it to a temperature greater than the melting point of the substance, or to have frozen contents melted (AMS, 2012). To free something from the binding action of ice by warming it to a temperature above the melting point of ice (AMS, 2012). A warm spell when ice and snow melt, for example, ‘January thaw’ (AMS, 2012)."@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       4 .

