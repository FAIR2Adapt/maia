<http://connectivity-hub.com/terms/ab03b1cb-622b-4988-bde0-214edf7f8240>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A widespread body of air, the approximately homogeneous properties of which (i) have been established while that air was situated over a particular region of the Earth’s surface, and (ii) undergo specific modifications while in transit away from the source region (AMS, 2021)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Air mass"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

