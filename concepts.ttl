<http://connectivity-hub.com/terms/2d6e1aaa-6307-463b-9cbe-bc7042c8b12d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A process of iteratively planning, implementing and modifying strategies for managing resources in the face of uncertainty and change. Adaptive management involves adjusting approaches in response to observations of their effect on, and changes in, the system brought on by resulting feedback effects and other variables (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Adaptive management"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

