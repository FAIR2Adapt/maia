<http://connectivity-hub.com/terms/153ff6fc-336b-4f2c-8d43-f31b7fed7a1a>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Rare radioactive isotopes that are created by the interaction of high-energy cosmic ray particles with atomic nuclei. They are often used as indicator of solar activity which modulates the cosmic rays’ intensity or as tracers of atmospheric transport processes, and are also called cosmogenic radionuclides."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Cosmogenic radioisotopes"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

