<http://connectivity-hub.com/terms/e27b481b-2aae-4839-bdd7-ce0d2c3cf698>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "An urban agglomeration with 10 million inhabitants or more (United Nations, Department of Economic and Social Affairs, Population Division (2019)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Megacity"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

