<http://connectivity-hub.com/terms/78f01d55-334b-4c88-8a1a-6639c53187e2>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The distribution of land or ice surface as a function of altitude."@en;
