<http://connectivity-hub.com/terms/0a645d23-8c18-47d3-857e-de91b7f2cb91>
        rdf:type           skos:Concept;
        dc:created         "2025-06-05T16:08:34.661Z"^^xsd:dateTime;
        dc:modified        "2025-06-05T16:09:10.738Z"^^xsd:dateTime;
        skos:definition    "The collection and interpretation of life accounts in interview and other forms with reference to story-construction with particular attention to the use of explanatory forms such as metaphors and experiences as well as being sensitive to the temporal sequence of such experiences (UNICEF, 2014)."@en;
        skos:historyNote   "https://www.unicef.cn/media/25521/file/Annex_2_-_2022_UNICEF_Booklet_for_RSE_EN.pdf"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Narrative analysis"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      3 .

