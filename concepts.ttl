<http://connectivity-hub.com/terms/e4d8905c-39a7-4925-9650-d0441cba4df4>
        rdf:type            skos:Concept;
        dc:modified         "2025-06-09T14:52:14.379Z"^^xsd:dateTime;
        skos:definition     "In the IPCC's WGII report, climate resilient development refers to the process of implementing greenhouse gas mitigation and adaptation measures to support sustainable development for all."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Climate resilient development"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

