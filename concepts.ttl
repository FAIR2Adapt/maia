<http://connectivity-hub.com/terms/98b392ce-37fd-4004-a089-36cf968f7567>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Process of forming of layers of ocean water with different properties such as salinity, density and temperature that act as barriers to water mixing. The strengthening of near-surface stratification generally results in warmer surface waters, decreased oxygen levels in deeper water and intensification of ocean acidification (OA) in the upper ocean."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Ocean stratification"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

