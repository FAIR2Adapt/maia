<http://connectivity-hub.com/terms/57dca12b-abbe-425c-bb7d-4fca6078afe7>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A refugium is a geographic area where a population found safety from some threat to its existence, for example, climate refugia or glacial refugia (refuge from glaciations)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Refugium"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

