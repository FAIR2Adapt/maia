<http://connectivity-hub.com/terms/53072dad-954b-4b63-beb2-88a565d8d406>
        rdf:type           skos:Concept;
        dc:created         "2025-06-09T15:19:00.283Z"^^xsd:dateTime;
        dc:modified        "2025-06-09T15:22:13.066Z"^^xsd:dateTime;
        skos:altLabel      "pluvial flooding"@en , "Rain flood"@en;
        skos:broader       <http://connectivity-hub.com/terms/58d1c857-2638-477d-bc96-ce5b3afc0ee0>;
        skos:definition    "Pluvial flooding occurs when the amount of rainfall exceeds the capacity of urban storm water drainage systems or the ground to absorb it. This excess water flows overland, ponding in natural or man-made hollows and low-lying areas or behind obstructions (FloodInfo.ie, n.d)."@en;
        skos:historyNote   "https://www.floodinfo.ie/about_frm/types_and_causes/#:~:text=2015/January%202016.-,Pluvial%20(Rainfall)%20flooding,lying%20areas%20or%20behind%20obstructions."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Pluvial flood"@en;
        skos:related       <http://connectivity-hub.com/terms/69f058a2-f022-4f6a-92a9-739291b61af8> , <http://connectivity-hub.com/terms/8d8bfa22-428a-4d08-a903-8a182aecc7f3> , <http://connectivity-hub.com/terms/bbdfb015-161b-4999-9d91-55afca84f685> , <http://connectivity-hub.com/terms/a1f198c3-44ae-428e-a062-b5a10dc68f83> , <http://connectivity-hub.com/terms/248003d7-9bb7-46ae-88c0-be597c08c09c> , <http://connectivity-hub.com/terms/064f8a52-1e43-45cc-bf56-1efa960fd435>;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      16 .

