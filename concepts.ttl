<http://connectivity-hub.com/terms/ce9540ac-889a-4e85-9462-94faeac5f869>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The climate system involves process interactions from the micro- to the global-scale. Any threshold for defining ‘large-scale’ is arbitrary. Understanding of large-scale climate variability and change requires knowledge of both the response to external forcings and the role of internal variability. Many external forcings have substantial hemispheric or continental scale variations. Modes of climate variability are driven by ocean-basin-scale processes. Thus we define large-scale to include ocean-basin and continental scales as well as hemispheric and global scales."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Large-scale"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

