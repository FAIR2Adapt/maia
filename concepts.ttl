<http://connectivity-hub.com/terms/1410821e-d414-4afe-b656-17e06b39618b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The synthesis of organic compounds by plants and microbes, on land or in the ocean, primarily by photosynthesis using light and carbon dioxide (CO2) as sources of energy and carbon, respectively. It can also occur through chemosynthesis, using chemical energy, for example, in deep sea vents."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/271997ca-ad3d-4d97-95f8-927927d4055e> , <http://connectivity-hub.com/terms/6e55e082-074f-42b5-b4fb-f29b6aa73bc1>;
        skos:prefLabel      "Primary production"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

