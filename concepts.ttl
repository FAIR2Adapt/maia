<http://connectivity-hub.com/terms/ba22e253-5625-4567-8df9-e5088a58c463>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Dynamic transition zones that have intense interaction between rural and urban economies, activities, households, and lifestyles. Neither fully rural or urban (Seto et al., 2010)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Peri-urban areas"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

