<http://connectivity-hub.com/terms/d6f6ea8c-a6a7-423c-b9cf-c9673365bf22>
        rdf:type           skos:Concept;
        dc:created         "2024-11-15T16:21:24.933Z"^^xsd:dateTime;
        dc:modified        "2025-01-03T09:53:37.695Z"^^xsd:dateTime;
        skos:altLabel      "indicators"@en;
        skos:definition    "Indicators are observable and measurable characteristics that can be used to simplify information to help understand the state of a concept or phenomenon, and/or to monitor it over time to show changes or progress towards achieving a specific change (Adapted from Ivčević et al. 2019; and Scotland’s\nInternational Development Alliance n.d. in Gill et al., 2022)."@en;
