<http://connectivity-hub.com/terms/af6a8944-0ebd-4faa-82f5-e5ecc74d29a7>
        rdf:type            skos:Concept;
        dc:modified         "2025-05-20T10:15:58.796Z"^^xsd:dateTime;
        skos:definition     "The baseline (or reference) is the state against which change is measured. A baseline period is the period relative to which anomalies are computed. The baseline concentration of a trace gas is that measured at a location not influenced by local anthropogenic emissions."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Baseline/reference"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

