<http://connectivity-hub.com/terms/ef4f9018-9585-43dd-bcf1-003297dcbf2c>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Direct or indirect actions undertaken with the aim of reinstating a level of ecosystem functionality, where the goal is provision of goods and services rather than ecological restoration (McDonald et al., 2016)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Land rehabilitation"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

