<http://connectivity-hub.com/terms/c447ef3e-e968-4eb1-a04f-3501d85e4503>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Kriging is a method of interpolation (normally spatial interpolation when used with atmospheric or oceanographic data) in which the interpolated values are estimated using a Gaussian process governed by prior covariances."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Kriging"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

