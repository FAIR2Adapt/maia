<http://connectivity-hub.com/terms/77795cfd-990e-44a8-8aa2-16b423cfcfc8>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Biodiversity or biological diversity means the variability among living organisms from all sources including, among other things, terrestrial, marine and other aquatic ecosystems, and the ecological complexes of which they are part; this includes diversity within species, between species and of ecosystems (UN, 1992)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/c9257a18-83ae-4f22-b7c2-463a99485b59> , <http://connectivity-hub.com/terms/07bbc103-9fc2-433b-a355-e8b8def859d2>;
        skos:prefLabel      "Biodiversity"@en;
        skos:related        <http://connectivity-hub.com/terms/cbf97925-4585-403f-a231-c0b46fc93736>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       4 .

