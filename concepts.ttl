<http://connectivity-hub.com/terms/7d12a100-fec2-4b3d-aaa5-923982586180>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The period from approximately 12.9 to 11.7 ka (thousand years before 1950), during the last deglacial transition, characterized by a temporary return to colder conditions in many locations, especially around the North Atlantic."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Younger Dryas"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

