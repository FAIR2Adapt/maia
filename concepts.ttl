<http://connectivity-hub.com/terms/92c2a3c9-6b8d-45bd-9f29-862257464bf7>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The process of assisting the recovery of land from a degraded state (IPBES, 2018; McDonald et al. 2016)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Land restoration"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

