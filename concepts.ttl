<http://connectivity-hub.com/terms/f0a1ca9a-397e-4c7d-9bde-fbbebb32f096>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The state of well-being in which an individual realises his or her own abilities, can cope with the normal stresses of life, can work productively and is able to contribute to his or her community."@en;
        skos:editorialNote  "source:IPCC Glossary AR6" , "source:UNDRR HIPS";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Mental health"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

