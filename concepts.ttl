<http://connectivity-hub.com/terms/d98cff0a-8f77-4609-8525-ad5b7335eda5>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The midwater layer (200–1000 m) in the open ocean in which oxygen saturation is the lowest in the ocean. The degree of oxygen depletion depends on the largely bacterial consumption of organic matter, and the distribution of the OMZs is influenced by large-scale ocean circulation. In coastal oceans, OMZs extend to the shelves and may also affect benthic ecosystems."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Oxygen minimum zone (OMZ)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

