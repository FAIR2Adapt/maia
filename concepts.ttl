<http://connectivity-hub.com/terms/aeca7a10-616d-42a9-9e0d-d52fbdb65762>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The time-mean (or representative) energy exchanges within the climate system (including energy energy exchanges at the surface and top-of-atmosphere). This also includes horizontal ocean and atmospheric heat transports."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Earth's energy flows"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

