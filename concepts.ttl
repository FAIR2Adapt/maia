<http://connectivity-hub.com/terms/0ea92d8a-e528-4fd1-a13a-7ac646db44c8>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Coastal areas below 10 m of elevation above sea level that are hydrologically connected to the sea."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Low Elevation Coastal Zones (LECZ)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

