<http://connectivity-hub.com/terms/887e36de-d1e4-4fbd-847f-4e215f1055b1>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A changing aspect of the climate system that influences a component of a human or natural system."@en;
