<http://connectivity-hub.com/terms/cf29152b-c111-4b4c-a56a-a377b7a751be>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The amount of emissions of carbon dioxide (CO2) released per unit of another variable such as gross domestic product (GDP), output energy use or transport."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Carbon intensity"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

