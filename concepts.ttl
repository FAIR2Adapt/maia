<http://connectivity-hub.com/terms/6460d3d1-1238-4a1a-b51b-292aaa67ad44>
        rdf:type            skos:Concept;
        dc:modified         "2025-06-03T13:09:41.677Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/3f88490f-4569-46ef-993e-c45a66ec76a9>;
        skos:definition     "A process of improving the terms of participation in society, particularly for people who are disadvantaged, through enhancing opportunities, access to resources and respect for rights (UN DESA 2016)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Social inclusion"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

