<http://connectivity-hub.com/terms/33811146-806a-4b68-bd7c-8b52271f3d49>
        rdf:type           skos:Concept;
        dc:created         "2025-06-06T14:42:57.316Z"^^xsd:dateTime;
        dc:modified        "2025-06-06T14:45:17.364Z"^^xsd:dateTime;
        skos:altLabel      "wicked problem"@en , "wicked problems"@en;
        skos:definition    "A problem that is categorized by a great number of uncertainties. These include: on the stakeholders involved, the boundaries of the problem, long term organisational developments and responsibilities, amongst others (adapted from Wijnmalen et al., 2015 in RESIN glossary, 2016)."@en;
        skos:historyNote   "https://ec.europa.eu/research/participants/documents/downloadPublic?documentIds=080166e5a5bef06e&appId=PPGMS"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Wicked problem"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      5 .

