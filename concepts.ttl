<http://connectivity-hub.com/terms/dc835584-f30a-494e-8373-9515c96a3840>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The amount of dissolved oxygen consumed by micro-organisms (bacteria) in the bio-chemical oxidation of organic and inorganic matter in wastewater."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Biochemical oxygen demand (BOD)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

