<http://connectivity-hub.com/terms/d32c5440-7744-4f43-aeac-b9de552eec6e>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The turbulent flux of heat from the Earth’s surface to the atmosphere that is associated with evaporation or condensation of water vapour at the surface; a component of the surface energy budget."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Latent heat flux"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

