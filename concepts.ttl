<http://connectivity-hub.com/terms/a974d81d-48d5-4118-afa9-2d9bb94eb685>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Justice is concerned with setting out the moral or legal principles of fairness and equity in the way people are treated, often based on the ethics and values of society."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/e25214c9-dc89-4f86-80ae-58970db33dcf> , <http://connectivity-hub.com/terms/396cc496-06cb-4cd4-bfc1-856450ceeba6> , <http://connectivity-hub.com/terms/bc868ae5-af3f-4ae4-b13a-0ce9ca09749c>;
        skos:prefLabel      "Justice"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

