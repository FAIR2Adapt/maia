<http://connectivity-hub.com/terms/1cf92dd7-eb77-4421-acd0-633aa647624e>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The meridional overturning circulation of the stratosphere transporting air upward in the tropics, poleward to the winter hemisphere, and downward at polar and subpolar latitudes. The Brewer–Dobson circulation is driven by the interaction between upward propagating planetary waves and the mean flow."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Brewer–Dobson circulation"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

