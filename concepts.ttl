<http://connectivity-hub.com/terms/9b117356-4016-4cab-9494-49088abd53e3>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The loss of oxygen in the ocean. It results from ocean warming, which reduces oxygen solubility and increases oxygen consumption and stratification, thereby reducing the mixing of oxygen into the ocean interior. Deoxygenation can also be exacerbated by the addition of excess nutrients in the coastal zone."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Ocean deoxygenation"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

