<http://connectivity-hub.com/terms/940a6b35-9bb2-4805-8bc6-18c77b247c0e>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Carbon released as carbon dioxide or methane from combustion or decomposition of biomass or biobased products. "@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Biogenic carbon emissions"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

