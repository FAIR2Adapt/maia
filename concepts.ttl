<http://connectivity-hub.com/terms/a4b1ee2b-13ff-4485-a362-59aef833068e>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A principle that ascribes equal worth to all human beings, including equal opportunities, rights and obligations, irrespective of origins."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/60ef6a61-e827-4896-a46f-54f3457eb21c>;
        skos:prefLabel      "Equality"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

