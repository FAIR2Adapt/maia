<http://connectivity-hub.com/terms/76fb5de6-6f4c-42aa-92f7-09e131f58ab7>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A proposed carbon dioxide removal (CDR) method that involves deposition of alkaline minerals or their dissociation products at the ocean surface. This increases surface total alkalinity, and may thus increase ocean carbon dioxide (CO2) uptake and ameliorate surface ocean acidification."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Ocean alkalinization/Ocean alkalinity enhancement"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

