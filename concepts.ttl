<http://connectivity-hub.com/terms/30620cd2-4922-4455-8a7c-1c2b0e70a8fa>
        rdf:type           skos:Concept;
        dc:created         "2025-06-03T11:16:20.782Z"^^xsd:dateTime;
        dc:modified        "2025-06-03T11:17:57.057Z"^^xsd:dateTime;
        skos:altLabel      "DEM"@en;
        skos:definition    "A Digital Elevation Model (DEM) is a representation of the bare ground (bare earth) topographic surface of the Earth excluding trees, buildings, and any other surface objects (USGS, 2025)."@en;
        skos:historyNote   "https://www.usgs.gov/faqs/what-a-digital-elevation-model-dem"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Digital elevation model"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      5 .

