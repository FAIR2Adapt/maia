<http://connectivity-hub.com/terms/c92bd3f3-8898-4370-a975-e7aedb8da591>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A partition value in a population distribution that a given percentage of the data values are below or equal to. The 50th percentile corresponds to the median of the population. Percentiles are often used to estimate the extremes of a distribution. For example, the 90th (10th) percentile may be used to refer to the threshold for the upper (lower) extremes."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Percentile"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

