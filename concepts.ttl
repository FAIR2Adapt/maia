<http://connectivity-hub.com/terms/a4499364-d6eb-49be-8559-df1613fd07f4>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A physicochemical process that transports dissolved inorganic carbon from the ocean’s surface to its interior. The solubility pump is primarily driven by the solubility of carbon dioxide (CO2) (with more CO2 dissolving in colder water) and the large-scale, thermohaline patterns of ocean circulation."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Solubility pump"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

