<http://connectivity-hub.com/terms/5f67931f-b777-471e-b7f0-a5e1ace0d0a4>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A consistent measurement of a characteristic of an object or activity that is otherwise difficult to quantify. Within the context of the evaluation of climate models, this is a quantitative measure of agreement between a simulated and an observed quantity which can be used to assess the performance of individual models."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Metric"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

