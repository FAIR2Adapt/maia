<http://connectivity-hub.com/terms/ebe8e418-34db-4152-b841-1506682132b8>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Human-driven activities that lead to changes in the climate system due to perturbations of the Earth’s energy budget (also called anthropogenic forcing). Human influence results from emissions of greenhouse gases, aerosols, ozone-depleting substances (ODSs), and land-use change."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Human influence on the climate system"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

