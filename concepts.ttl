<http://connectivity-hub.com/terms/74de1032-76aa-4ba1-b3a1-c900dc308f52>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Activities that help satisfy human wants or needs. While they usually involve relationships between producers and consumers, services are less tangible and less storable than goods since they represent flows not stocks, and when their regeneration conditions are protected they may be reused over time."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Services"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
PREFIX dc:      <http://purl.org/dc/terms/>
PREFIX dct:     <http://purl.org/dc/terms/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dme:     <https://grafsync.graphifi.com/schema/dm-entitlement/>
PREFIX ent:     <https://graphifi.com/schema/entitlement/>
PREFIX gs:      <https://grafsync.graphifi.com/schema/gs/>
