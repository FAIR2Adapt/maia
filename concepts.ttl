<http://connectivity-hub.com/terms/f9dbf392-d5e6-4aaf-aa32-b689581afa14>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The enhancement of the growth of plants as a result of increased atmospheric carbon dioxide (CO2) concentration."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Carbon dioxide (CO2) fertilization"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

