<http://connectivity-hub.com/terms/59e4aa08-2db6-4fea-9776-0c29f994b8b1>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A device at a coastal or deep-sea location that continuously measures the level of the sea with respect to the adjacent land. Time averaging of the sea level so recorded gives the observed secular changes of the relative sea level."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Tide gauge"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

