<http://connectivity-hub.com/terms/eba4afe2-743d-4e8a-82ac-0ce7edb5a679>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The upper limit of tree growth in mountains or at high latitudes. It is more elevated or more poleward than the forest line."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Tree line"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

