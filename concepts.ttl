<http://connectivity-hub.com/terms/79db6a27-c7fb-45a7-a8f1-ec8746ced8cf>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Approach to reconstructing the past temporal and spatial characteristics of a climate variable from predictors. The predictors can be instrumental data if the reconstruction is used to infill missing data or proxy data if it is used to develop paleoclimate reconstructions. Various techniques have been developed for this purpose: linear multivariate regression-based methods and non-linear Bayesian and analogue methods."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Reconstruction (of climate variable)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
PREFIX dc:      <http://purl.org/dc/terms/>
PREFIX dct:     <http://purl.org/dc/terms/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dme:     <https://grafsync.graphifi.com/schema/dm-entitlement/>
PREFIX ent:     <https://graphifi.com/schema/entitlement/>
PREFIX gs:      <https://grafsync.graphifi.com/schema/gs/>
PREFIX ome:     <https://grafsync.graphifi.com/schema/om-entitlement/>
PREFIX owl:     <http://www.w3.org/2002/07/owl#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
