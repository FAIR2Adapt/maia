<http://connectivity-hub.com/terms/26e5ea01-6866-4d72-b398-3ea54e2740cb>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "In climate models, this term refers to the physical distance (metres or degrees) between each point on the grid used to compute the equations. Temporal resolution refers to the time step or time elapsed between each model computation of the equations."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Resolution"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

