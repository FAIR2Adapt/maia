<http://connectivity-hub.com/terms/21b6b68c-01a4-48d3-bded-2e81725271cd>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The chance of a specific outcome occurring, where this might be estimated probabilistically. Likelihood is expressed in this report using a standard terminology (Mastrandrea et al., 2010). "@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Likelihood"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

