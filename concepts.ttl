<http://connectivity-hub.com/terms/68bd3017-5ad8-492e-8bf7-b4fab66d2570>
        rdf:type           skos:Concept;
        dc:created         "2024-11-08T11:54:34.519Z"^^xsd:dateTime;
        dc:modified        "2025-01-03T09:51:04.557Z"^^xsd:dateTime;
        skos:altLabel      "post-disaster recovery"@en;
        skos:definition    "The restoring or improving of livelihoods and health, as well as economic, physical, social, cultural and environmental assets, systems and activities, of a disaster-affected community or society, aligning with the principles of sustainable development and “build back better”, to avoid or reduce future disaster risk (UNDRR, 2016 in Gill et al., 2022)"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Disaster recovery"@en;
        skos:related       <http://connectivity-hub.com/terms/aef81e7e-0911-4d2a-bca1-a457d62730eb> , <http://connectivity-hub.com/terms/99596d76-6804-426b-b6fd-cbda6c842031> , <http://connectivity-hub.com/terms/d22c4c9f-cf8c-4820-bb1e-7dcae6bc3ea0>;
