<http://connectivity-hub.com/terms/4a2f6987-859b-466e-a8e0-1e05580a2831>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The lowest part of the atmosphere, below the tropopause, where clouds and weather phenomena occur. In the troposphere, temperatures generally decrease with height."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Troposphere"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

