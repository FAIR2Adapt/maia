<http://connectivity-hub.com/terms/79ae254f-fe72-4358-9722-73669c940f18>
        rdf:type           skos:Concept;
        dc:created         "2024-10-04T10:23:27.999Z"^^xsd:dateTime;
        dc:modified        "2024-10-07T13:52:57.025Z"^^xsd:dateTime;
        skos:altLabel      "energy behaviour"@en , "energy"@en , "energy challenge"@en , "energy class"@en;
        skos:definition    "The power of 'doing work' possessed at any instant by a body or system of bodies. Energy is classified in a variety of types and becomes available to human ends when it flows from one place to another or is converted from one type into another. AR5-WG3 (04/2014)"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:narrower      <http://connectivity-hub.com/terms/a8523b5a-c5f2-4742-8979-a17065c18cdf> , <http://connectivity-hub.com/terms/697aebc7-7160-4bd3-a532-fe35f87a8ab1> , <http://connectivity-hub.com/terms/6711212c-47ca-43c4-a534-7d7577de21bc>;
        skos:prefLabel     "Energy"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/> .

