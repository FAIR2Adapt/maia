<http://connectivity-hub.com/terms/430c45ee-88dc-4671-aa12-bc4af32d6c6a>
        rdf:type           skos:Concept;
        dc:created         "2024-11-29T11:52:07.46Z"^^xsd:dateTime;
        dc:modified        "2025-01-03T09:55:50.716Z"^^xsd:dateTime;
        skos:definition    "The level of magnitude of a system process at which sudden or rapid change occurs. A point or level at which new properties emerge in an ecological, economic or other system, invalidating predictions based on mathematical relationships that apply at lower levels (IPCC, 2007 in Gill et al., 2022)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:narrower      <http://connectivity-hub.com/terms/eaebe6d5-9eb7-4b39-a61a-ac5795d9631a>;
        skos:prefLabel     "Threshold"@en;
        skos:related       <http://connectivity-hub.com/terms/5803d73a-7897-46b3-bea2-db867382a888>;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      6 .

