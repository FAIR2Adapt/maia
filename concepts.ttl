<http://connectivity-hub.com/terms/f061eab0-82fc-44a8-929b-e810755c61de>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Land management changes which increase the soil organic carbon content, resulting in a net removal of carbon dioxide (CO2) from the atmosphere."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Soil carbon sequestration (SCS)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

