<http://connectivity-hub.com/terms/b0097e5c-a7f6-4eac-b087-a665df810256>
        rdf:type           skos:Concept;
        dc:created         "2024-11-05T17:20:51.928Z"^^xsd:dateTime;
        dc:modified        "2025-01-03T09:48:53.312Z"^^xsd:dateTime;
        skos:definition    "An adaptation tipping point (ATP) is the moment when the magnitude of change is such that a current management strategy can no longer meet its objectives. As a result, adaptive management is needed to prevent or postpone these ATPs (Nanda et al, 2018 in Gill et al., 2022)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Adaptation tipping points"@en;
        skos:related       <http://connectivity-hub.com/terms/5803d73a-7897-46b3-bea2-db867382a888> , <http://connectivity-hub.com/terms/2bc764bb-860a-4d14-814d-72b8bdd68012>;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      10 .

