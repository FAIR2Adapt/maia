<http://connectivity-hub.com/terms/4e019e9c-7b28-493a-b8aa-3c73207919b4>
        rdf:type           skos:Concept;
        dc:created         "2024-11-15T16:48:08.439Z"^^xsd:dateTime;
        dc:modified        "2025-01-03T09:54:10.605Z"^^xsd:dateTime;
        skos:definition    "Risk generated from multiple hazards and the interrelationships between these hazards (but not considering interrelationships on the vulnerability level) (Zschau, 2017 in Gill et al., 2022)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Multi-hazard risk"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      6 .

