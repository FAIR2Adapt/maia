<http://connectivity-hub.com/terms/ac850a0b-0317-4a49-a90b-5e60dbeea1db>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Techniques used to represent the spatial variations in climate at a given increase in global mean surface air temperature (GSAT) are referred to as ‘pattern scaling’."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Pattern scaling"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

