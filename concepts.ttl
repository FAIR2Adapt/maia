<http://connectivity-hub.com/terms/cbe17199-69f6-4700-96ec-2819a241bbf2>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A perennial mass of ice, and possibly firn and snow, originating on the land surface by accumulation and compaction of snow and showing evidence of past or present flow. A glacier typically gains mass by accumulation of snow and loses mass by ablation. Land ice masses of continental size (>50,000 km2) are referred to as ice sheets (Cogley et al., 2011)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/cbf1d9dc-b9c2-4739-8e9b-763ca5c8cec3>;
        skos:prefLabel      "Glacier"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
PREFIX dc:      <http://purl.org/dc/terms/>
PREFIX dct:     <http://purl.org/dc/terms/>
