<http://connectivity-hub.com/terms/77b5d9d0-fe10-4719-bcca-3beb1de651e8>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Nitrogen deposition is defined as the nitrogen transferred from the atmosphere to the Earth’s surface by the processes of wet deposition and dry deposition."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Nitrogen deposition"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

