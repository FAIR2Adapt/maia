<http://connectivity-hub.com/terms/be4aace2-2035-4d69-9974-46bda8f8b98e>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "An assessment of carbon cycle sources and sinks on a global level, through the synthesis of evidence for fossil-fuel and cement emissions, landuse change emissions, ocean and land CO2 sinks, and the resulting atmospheric CO2 growth rate. "@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Global carbon budget"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

