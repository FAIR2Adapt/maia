<http://connectivity-hub.com/terms/fd99feea-700e-44e2-b26a-7189e7fb7671>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Phases three and five of the Coupled Model Intercomparison Project (CMIP3 and CMIP5), coordinating and archiving climate model simulations based on shared model inputs by modeling groups from around the world. The CMIP3 multi-model data set includes projections using SRES scenarios. The CMIP5 data set includes projections using the Representative Concentration Pathways."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "CMIP3 and CMIP5"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
PREFIX dc:      <http://purl.org/dc/terms/>
PREFIX dct:     <http://purl.org/dc/terms/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dme:     <https://grafsync.graphifi.com/schema/dm-entitlement/>
PREFIX ent:     <https://graphifi.com/schema/entitlement/>
PREFIX gs:      <https://grafsync.graphifi.com/schema/gs/>
PREFIX ome:     <https://grafsync.graphifi.com/schema/om-entitlement/>
PREFIX owl:     <http://www.w3.org/2002/07/owl#>
