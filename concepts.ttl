<http://connectivity-hub.com/terms/c037b86b-980d-4e0e-af70-9756eac819e9>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/083e4731-556e-4012-810a-a961d2777362>;
        skos:definition     "An approach to agriculture that aims to transform and reorient agricultural systems to effectively support development and ensure food security in a changing climate by sustainably increasing agricultural productivity and incomes, adapting and building resilience to climate change, and reducing and/or removing greenhouse gas emissions, where possible (FAO, 2018)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Climate-smart agriculture (CSA)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

