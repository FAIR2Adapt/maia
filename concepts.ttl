<http://connectivity-hub.com/terms/24c34254-4521-4dbc-9905-12b52d90189b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The gradual removal of atmospheric carbon dioxide (CO2) through dissolution of silicate and carbonate rocks. Weathering may involve physical processes (mechanical weathering) or chemical activity (chemical weathering)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Weathering"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

