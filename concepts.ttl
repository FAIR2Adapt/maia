<http://connectivity-hub.com/terms/4ce59d44-f71c-4622-b06c-f2d9a83f2893>
        rdf:type           skos:Concept;
        dc:created         "2025-06-05T15:07:24.657Z"^^xsd:dateTime;
        dc:modified        "2025-06-05T15:08:15.796Z"^^xsd:dateTime;
        skos:definition    "The analysis of both written and spoken language in relation to its social context and refers to the way that different types of language construct meaning (Newcastle University, n.d)."@en;
        skos:historyNote   "Newcastle University. (n.d.). Discourse analysis. Methods Hub. https://research.ncl.ac.uk/methodshub/methods/discourseanalysis/"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Discourse analysis"@en;
        skos:related       <http://connectivity-hub.com/terms/f0fdbbf6-605e-40ac-9994-eff1e7c56292> , <http://connectivity-hub.com/terms/da2f27df-51e3-4bbd-bfe4-42fea655eea6>;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      5 .

