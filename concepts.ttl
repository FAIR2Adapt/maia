<http://connectivity-hub.com/terms/737319cc-879d-45bf-9929-3010995bcb9e>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The production of carbohydrates in plants, algae and some bacteria using the energy of light. Carbon dioxide (CO2) is used as the carbon source."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Photosynthesis"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

