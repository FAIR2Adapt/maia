<http://connectivity-hub.com/terms/41db08c9-fb69-4ee7-83ab-c9b930c6dc7c>
        rdf:type            skos:Concept;
        dc:modified         "2025-06-05T13:55:08.726Z"^^xsd:dateTime;
        skos:definition     "A forecast made for a period in the past using only information available before the beginning of the forecast. A sequence of hindcasts can be used to calibrate the forecast system and/or provide a measure of the average skill that the forecast system has exhibited in the past as a guide to the skill that might be expected in the future."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Hindcast or retrospective forecast"@en;
        skos:related        <http://connectivity-hub.com/terms/cb002cb8-5850-481b-b3e2-421ce6bb0eeb> , <http://connectivity-hub.com/terms/5b58c0e2-49fe-4a7e-9754-aa60a348cbd5>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       3 .

