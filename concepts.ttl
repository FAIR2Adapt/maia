<http://connectivity-hub.com/terms/b79cdf73-3a86-40f1-91a7-b36328b5af1b>
        rdf:type           skos:Concept;
        dc:created         "2024-11-08T11:15:04.584Z"^^xsd:dateTime;
        dc:modified        "2025-01-03T09:50:04.777Z"^^xsd:dateTime;
        skos:altLabel      "bayesian inference"@en , "bayesian models"@en , "bayesian methods"@en;
        skos:definition    "A Bayesian method is a method by which a statistical analysis of an unknown or uncertain quantity(ies) is carried out in two steps. First, a prior probability distribution for the uncertain quantity(ies) is formulated on the basis of existing knowledge (either by eliciting expert opinion or by using existing data and studies). At this first stage, an element of subjectivity may influence the choice, but in many cases, the prior probability distribution can be chosen as neutrally as possible, in order not to influence the final outcome of the analysis. In the second step, newly acquired data are used to update the prior distribution into a posterior distribution. The update is carried out either through an analytic computation or though numeric approximation, using a theorem formulated by and named after the British mathematician Thomas Bayes (1702-1761) (IPCC, AR5, 2013)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Bayesian method/approach"@en;
        skos:related       <http://connectivity-hub.com/terms/bd046f17-9ac4-4def-af1f-3802b401b09a>;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      6 .

