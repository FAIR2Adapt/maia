<http://connectivity-hub.com/terms/ce53eab6-be2f-4aa7-975e-5354aa5e0815>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A benefit or amenity (e.g., mobility, communication, thermal comfort) received as a result of energy or other resources use."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Energy services"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

