<http://connectivity-hub.com/terms/2d894054-1c35-4a07-be4a-de20d2496ebf>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The ongoing changes in gravity, rotation and viscoelastic solid Earth deformation (GRD) in response to past changes in the distribution of ice and water on Earth’s surface. On a time scale of decades to tens of millennia following mass redistribution, Earth’s mantle flows viscously as it evolves toward isostatic equilibrium, causing solid Earth movement and geoid changes, which can result in regional-to-local sea level variations."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Glacial isostatic adjustment (GIA)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

