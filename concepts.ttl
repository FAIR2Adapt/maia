<http://connectivity-hub.com/terms/da886285-c496-4041-af60-2ea68f7219ec>
        rdf:type           skos:Concept;
        dc:created         "2025-06-05T14:50:10.94Z"^^xsd:dateTime;
        dc:modified        "2025-06-06T14:40:34.088Z"^^xsd:dateTime;
        skos:definition    "Designing for transitions is a way of designing that takes a systems thinking and long term approach, focussing on progress, and creating interventions that move the whole system to a better state. It asks for an ongoing process and journey, noting that we cannot design single fixes for these systems (Coops et al., 2022)."@en;
        skos:historyNote   "Coops, F., Hummels, C., Dorst, K., Goldstein, B.E., Loorbach, D., and Gaziulusoy, İ. (2022) Designing for\ntransitions and transformations, in Lockton, D., Lenzi, S., Hekkert, P ., Oak, A., Sádaba, J., Lloyd, P . (eds.),\nDRS2022: Bilbao, 27 June - 3 July, Bilbao, Spain. https://doi.org/10.21606/drs.2022.897"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Design for transitions"@en;
        skos:related       <http://connectivity-hub.com/terms/f9ac95da-a8eb-40b4-b19c-cbbb16091359> , <http://connectivity-hub.com/terms/52d58acc-a42f-4024-8282-868c6bf6541f> , <http://connectivity-hub.com/terms/5770d7e9-d56b-48cf-b31b-eb559b92265a> , <http://connectivity-hub.com/terms/5b298da2-959d-4f79-b5eb-0e4c194f7df5>;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      7 .

