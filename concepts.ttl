<http://connectivity-hub.com/terms/6c32a634-0ca0-42ed-8833-acad1b36734c>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A dimensionless measure of the acidity of a dilute solution (e.g., seawater) based on the activity, or effective concentration, of hydrogen ions (H+) in the solution. pH is measured on a logarithmic scale where pH = –log10(H+). Thus, a pH decrease of 1 unit corresponds to a 10-fold increase in the acidity, or the activity of H+."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "pH"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

