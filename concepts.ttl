<http://connectivity-hub.com/terms/b9f6155f-ac33-4f03-94a9-3c908c023e9b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The stewardship and use of land resources, including soils, water, animals and plants, to meet changing human needs, while simultaneously ensuring the long-term productive potential of these resources and the maintenance of their environmental functions."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Sustainable land management"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
PREFIX dc:      <http://purl.org/dc/terms/>
PREFIX dct:     <http://purl.org/dc/terms/>
