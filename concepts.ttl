<http://connectivity-hub.com/terms/ae5cccae-a488-4a27-a751-5919c503f974>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Global average of near-surface air temperatures over land, oceans and sea ice. Changes in GSAT are often used as a measure of global temperature change in climate models."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Global mean surface air temperature (GSAT)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

