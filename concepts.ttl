<http://connectivity-hub.com/terms/a8523b5a-c5f2-4742-8979-a17065c18cdf>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime , "2024-10-04T10:59:15.428Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/79ae254f-fe72-4358-9722-73669c940f18>;
        skos:definition     "The energy that is embodied in resources as they exist in nature (e.g., coal, biomass uranium, solar radiation, wind, ocean currents) (Grubler et al. 2012). [Note: Primary energy is defined in several alternative ways. The method used in this report is the direct equivalent method, which counts one unit of secondary energy provided from non-combustible sources as one unit of primary energy. For more details on the methodology, see Section 7 in Working Group III Annex II.]"@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Primary energy"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
