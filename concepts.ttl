<http://connectivity-hub.com/terms/102f925f-01b9-46af-b2c5-4a9f9a14692c>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:altLabel       "Reservoir overtopping"@en;
        skos:definition     "A reservoir is an artificial lake where water is stored (National Geographic, 2020). Reservoir flooding occurs when excess rainfall causes the lake level to rise or flood water to spill downstream. <br /> <p>National Geographic, 2020. <a href=\"https://www.nationalgeographic.org/society/\">Reservoir. National Geographic Encyclopaedia</a>. Accessed 30 October 2020.</p>"@en;
        skos:editorialNote  "source:UNDRR HIPS";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Reservoir Flooding"@en;
        skos:scopeNote      "Reservoirs are artificially created lakes that are usually formed by building a dam across a river. When a dam fails, a large volume of water is suddenly released from the reservoir, resulting in downstream land or properties being flooded (Cheshire East Council, 2020). Metrics and numeric limits Not identified."@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       4 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
PREFIX dc:      <http://purl.org/dc/terms/>
PREFIX dct:     <http://purl.org/dc/terms/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dme:     <https://grafsync.graphifi.com/schema/dm-entitlement/>
PREFIX ent:     <https://graphifi.com/schema/entitlement/>
PREFIX gs:      <https://grafsync.graphifi.com/schema/gs/>
