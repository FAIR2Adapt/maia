<http://connectivity-hub.com/terms/0edd04af-91f5-440a-861a-aa10b84d7f9b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The sum of land-use practices (e.g., sowing, fertilising, weeding, harvesting, thinning and clear-cutting) that take place within broader land-use categories (Pongratz et al., 2018)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/7c7a17da-e54b-43df-8fc3-43edf93a389e>;
        skos:prefLabel      "Land management"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

