<http://connectivity-hub.com/terms/38724378-9967-40d2-a34f-e19dcc2443d0>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Replacement of one material (including an energy carrier used as a feedstock) by another, due to scarcity, price, technological change, or because of lower environmental impacts or greenhouse gas emissions."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Material substitution"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

