<http://connectivity-hub.com/terms/601079cb-2c72-4d0c-9f27-a5a3efd94453>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The upper limit of the closed upper montane forest or forest at high latitudes. It is less elevated or less poleward than the tree line."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Forest line"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
