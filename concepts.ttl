<http://connectivity-hub.com/terms/e59570f8-abd4-4b73-8134-717cbfa29479>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A measure of how hot the air feels to the human body. The index is mainly based on surface air temperature and relative humidity and thus reflects the combined effect of high temperature and humidity on human physiology and provides a relative indication of potential health risks."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Heat index"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
PREFIX dc:      <http://purl.org/dc/terms/>
