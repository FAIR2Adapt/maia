<http://connectivity-hub.com/terms/e8c9d31b-844d-42fb-917e-62cec83ddbc6>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Regional climate messages translate climate information synthesized from different lines of evidence into the context of a user vulnerable to climate at regional scales taking into account the values of both the producer and user (Section 10.5 of the AR6 WGI report)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Regional climate messages"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

