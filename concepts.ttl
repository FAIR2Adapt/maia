<http://connectivity-hub.com/terms/4b9730f2-b9b7-47b4-8749-3546376a6f44>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The Quaternary Period is the last of three periods that make up the Cenozoic Era (66 Ma to present), extending from 2.58 Ma to the present, and includes the Pleistocene and Holocene Epochs."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Quaternary"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

