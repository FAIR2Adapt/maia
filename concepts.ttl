<http://connectivity-hub.com/terms/1c58792d-e519-4fcc-ab90-f04270053876>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The thermodynamic relationship between temperature and the vapour pressure of a substance in which two phases of the substance are in equilibrium (e.g., liquid water and water vapour). For gases such as water vapour, this relation gives the increase in equilibrium (or saturation) vapour pressure per unit change in air temperature."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Clausius–Clapeyron equation/relationship"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

