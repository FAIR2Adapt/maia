<http://connectivity-hub.com/terms/ba9243f2-884e-4505-8169-2b662be52d34>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The responses of persons or groups to a particular situation, here likely to relate to climate change. Human behaviour covers the range of actions by individuals, communities, organisations, governments and at the international level."@en;
        skos:editorialNote  "source:IPCC Glossary AR6" , "source:UNDRR HIPS";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/c386e41b-c37a-4ba1-b8d8-2f87bf1bae29>;
        skos:prefLabel      "Human behaviour"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

