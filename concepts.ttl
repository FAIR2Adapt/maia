<http://connectivity-hub.com/terms/7417a1da-7fec-4339-980b-ad96cf0ae12d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The ratio of actual water vapour pressure to that at saturation with respect to liquid water or ice at the same temperature."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Relative humidity"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

