<http://connectivity-hub.com/terms/dc307fb3-3da1-4b12-9e0b-edbbbc6c3578>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A potential carbon dioxide removal (CDR) method that aims to artificially pump up cooler, nutrient-rich waters from deep in the ocean to the surface. The aim is to stimulate phytoplankton activity and thereby increase ocean CO2 uptake."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Artificial ocean upwelling (AOUpw)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

