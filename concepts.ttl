<http://connectivity-hub.com/terms/7eb8aae1-d0ad-4745-80b6-1f8e47b1f4ad>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Global dimming refers to the observed widespread reduction in the amount of solar radiation received at the Earth’s surface from the 1950s to the 1980s, with an increase in anthropogenic aerosol emissions appearing to have contributed. This was followed by a partial recovery since the 1990s (‘brightening’), particularly in industrialized areas, coincident with a reduction in anthropogenic aerosol emissions."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Global dimming"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

