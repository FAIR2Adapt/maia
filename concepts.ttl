<http://connectivity-hub.com/terms/d90b43bd-bbae-44c2-93af-ce72216944fb>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The process of changing from one state or condition to another in a given period of time. Transition can occur in individuals, firms, cities, regions and nations, and can be based on incremental or transformative change."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/9786f40d-da40-4e8c-9ac5-3608dddaaa0d>;
        skos:prefLabel      "Transition"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

