<http://connectivity-hub.com/terms/37e8576b-8e1f-4299-a559-1469f8871c3d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A system of practices for stewardship and use of forest land aimed at fulfilling relevant ecological (including biological diversity), economic and social functions of the forest in a sustainable manner (UNFCCC, 2002)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Forest management"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

