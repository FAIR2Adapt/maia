<http://connectivity-hub.com/terms/dcc21d6f-baae-4256-8cc3-3a6ee27e5608>
        rdf:type           skos:Concept;
        dc:created         "2025-06-03T13:11:50.961Z"^^xsd:dateTime;
        dc:modified        "2025-06-03T13:16:49.918Z"^^xsd:dateTime;
        skos:altLabel      "reflexive"@en;
        skos:definition    "Reflexivity involves questioning one's own taken for granted assumptions (Westling et al., 2019)."@en;
        skos:historyNote   "E.L Westling, L. Sharp, D. Scott, S. Tait, M. Rychlewski, R.M. Ashley, (2019). Reflexive adaptation for resilient water services: Lessons for theory and practice. Global Environmental Change, 57,101937. SSN 0959-3780. https://doi.org/10.1016/j.gloenvcha.2019.101937.\n\nFinlay, L. (2002). Negotiating the swamp: the opportunity and challenge of reflexivity in research practice. Qualitative Research, 2(2), 209-230. https://doi.org/10.1177/146879410200200205 (Original work published 2002)"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Reflexivity"@en;
        skos:scopeNote     "When applied to research, ‘reflexivity’ can be described as ‘examining how the researcher and inter-subjective elements impinge on, and even transform, research’ (Finlay, 2002, p.210)."@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      7 .

