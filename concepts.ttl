<http://connectivity-hub.com/terms/06f6992a-a815-4c47-946b-38fbc1e89767>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A reservoir in the Earth System where elements, such as carbon and nitrogen, reside in various chemical forms for a period of time."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Pool, carbon and nitrogen"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

