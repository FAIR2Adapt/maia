<http://connectivity-hub.com/terms/18e566cb-f2a6-4f75-8b1f-e609b6413956>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Accessible thermal energy stored in the Earth’s interior, in both rock and trapped steam or liquid water (hydrothermal resources), which may be used to generate electric energy in a thermal power plant, or to supply heat to any process requiring it. The main sources of geothermal energy are the residual energy available from planet formation and the energy continuously generated from radionuclide decay."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Geothermal energy"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

