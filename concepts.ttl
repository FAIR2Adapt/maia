<http://connectivity-hub.com/terms/1dd5e683-5079-4895-adbc-f40e1b3369f1>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The kinds of food that follow a particular pattern that a person or community eats (FAO and Alliance of Biodiversity International and CIAT, 2021)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Diet"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

