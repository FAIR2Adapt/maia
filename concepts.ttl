<http://connectivity-hub.com/terms/e2508d83-bb57-4e14-835b-f07c8a59008b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A relatively pure form of carbon, also known as soot, arising from the incomplete combustion of fossil fuels, biofuel, and biomass. It only stays in the atmosphere for days or weeks. BC is a climate forcing agent with strong warming effect, both in the atmosphere and when deposited on snow or ice."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Black carbon (BC)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

