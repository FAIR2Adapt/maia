<http://connectivity-hub.com/terms/58d1c857-2638-477d-bc96-ce5b3afc0ee0>
        rdf:type            skos:Concept;
        dc:modified         "2025-06-09T15:21:40.808Z"^^xsd:dateTime , "2024-10-04T11:17:45.488Z"^^xsd:dateTime;
        skos:definition     "The overflowing of the normal confines of a stream or other water body, or the accumulation of water over areas that are not normally submerged. Floods can be caused by unusually heavy rain, for example, during storms and cyclones. Floods include river (fluvial) floods, flash floods, urban floods, rain (pluvial) floods, sewer floods, coastal floods, and glacial lake outburst floods (GLOFs)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6" , "source:UNDRR HIPS";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/a1f198c3-44ae-428e-a062-b5a10dc68f83> , <http://connectivity-hub.com/terms/bbdfb015-161b-4999-9d91-55afca84f685> , <http://connectivity-hub.com/terms/53072dad-954b-4b63-beb2-88a565d8d406>;
        skos:prefLabel      "Flood"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       3 .

