<http://connectivity-hub.com/terms/24a07f25-ee92-4864-94dc-58ec9c6233ba>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A state of incomplete knowledge that can result from a lack of information or from disagreement about what is known or even knowable. It may have many types of sources, from imprecision in the data to ambiguously defined concepts or terminology, incomplete understanding of critical processes or uncertain projections of human behaviour. Uncertainty can therefore be represented by quantitative measures (e.g., a probability density function) or by qualitative statements (e.g., reflecting the judgement of a team of experts) (Moss and Schneider, 2000; IPCC, 2004; Mastrandrea et al., 2010) (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/184b242c-189b-4e96-9da3-c2c47a001456> , <http://connectivity-hub.com/terms/fe93c919-7765-4c03-b9af-10856e6d452f> , <http://connectivity-hub.com/terms/995efb27-fccf-44c6-a7a5-57f201b6bbee>;
        skos:prefLabel      "Uncertainty"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

