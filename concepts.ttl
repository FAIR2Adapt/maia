<http://connectivity-hub.com/terms/db772d68-6c21-4494-9ca7-48b56fee7c87>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The involuntary movement, individually or collectively, of persons from their country or community, notably for reasons of armed conflict, civil unrest, or natural or human-made disasters (adapted from IOM, 2011 in IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "(Internal) Displacement (of humans)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       4 .

