<http://connectivity-hub.com/terms/3794f23f-4ea0-499a-afb7-d92a96a093ba>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A near-periodic oscillation of the equatorial zonal wind between easterlies and westerlies in the tropical stratosphere with a mean period of around 28 months. The alternating wind maxima descend from the base of the mesosphere down to the tropopause and are driven by wave energy that propagates up from the troposphere."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Quasi-Biennial Oscillation (QBO)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

