<http://connectivity-hub.com/terms/62008731-94ff-454a-8291-aea39d0a71a8>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A minor constituent of the atmosphere, next to nitrogen and oxygen that together make up 99 % of all volume. The most important trace gases contributing to the greenhouse effect are carbon dioxide (CO2), ozone (O3), methane (CH4), nitrous oxide (N2O), perfluorocarbons (PFCs), chlorofluorocarbons (CFCs), hydrofluorocarbons (HFCs), sulphur hexafluoride (SF6) and water vapour (H2O)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Trace gas"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

