<http://connectivity-hub.com/terms/174210b5-593e-447a-b201-51f430a0d1e5>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A fuel, generally in liquid form, produced from biomass. Biofuels include bioethanol from sugarcane, sugar beet or maize, and biodiesel from canola or soybeans."@en;
