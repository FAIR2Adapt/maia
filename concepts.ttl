<http://connectivity-hub.com/terms/fdcab020-8c99-4549-a816-d1eca5b4e2d1>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Direct Services: Services (e.g., passenger mobility) required by end-users (consumers).Indirect services: Services required (e.g., goods transport, manufacturing) for provisioning systems of direct services."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Direct and indirect services"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

