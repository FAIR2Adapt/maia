<http://connectivity-hub.com/terms/35235b5a-2830-4bc8-b39c-068ff3d6d293>
        rdf:type           skos:Concept;
        dc:created         "2025-06-06T14:02:10.487Z"^^xsd:dateTime;
        dc:modified        "2025-06-06T14:04:33.089Z"^^xsd:dateTime;
        skos:altLabel      "Prototypes"@en;
        skos:definition    "A prototype is an early sample, model, or release of a product or system built to test a concept or assumption or to act as a thing to be tested and learned from (Perkins, 2015)."@en;
        skos:historyNote   "Perkins, S. (2015, December 18). What is prototyping anyway? UNHCR Innovation. https://www.unhcr.org/innovation/what-is-prototyping-anyway/"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Prototype"@en;
        skos:scopeNote     "Prototypes do not just refer models. We can prototype any idea - it can be the first draft of a road map, the wording of a policy, the steps of a system (Perkins, 2015)."@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      8 .

