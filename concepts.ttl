<http://connectivity-hub.com/terms/9e686b77-b67c-4ef5-a0b0-586551d7be4d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A method of analysis that combines results and models from the physical, biological, economic and social sciences and the interactions among these components in a consistent framework to evaluate the status and consequences of environmental change and the policy responses to it."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Integrated assessment"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

