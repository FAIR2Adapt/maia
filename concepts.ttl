<http://connectivity-hub.com/terms/96d430f5-03d3-467d-bd08-1f26349a333d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Measure of the exclusive total amount of emissions of carbon dioxide (CO2) that is directly and indirectly caused by an activity or is accumulated over the lifecycle stages of a product (Wiedmann and Minx, 2008)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/b7b28a09-641f-4254-93df-8d9c3fc82bea>;
        skos:prefLabel      "Carbon footprint"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

