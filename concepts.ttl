<http://connectivity-hub.com/terms/5e3d2439-7b45-4c8c-a262-6a5cfff34fcb>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The total of arrangements, activities and inputs applied to a parcel of land. The term land use is also used in the sense of the social and economic purposes for which land is managed (e.g., grazing, timber extraction, conservation and city dwelling). In national greenhouse gas (GHG) inventories, land use is classified according to the IPCC land-use categories of forest land, cropland, grassland, wetlands, settlements and other lands (see the 2006 IPCC Guidelines for National GHG Inventories and their 2019 Refinement for details (IPCC, 2006, 2019))."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Land use"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

