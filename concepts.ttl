<http://connectivity-hub.com/terms/4a78c4c9-2ef1-454d-ac3e-52b4c39d8510>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A technique of both relative dating and environmental reconstruction, consisting of the identification and counting of pollen types preserved in peat, lake sediments and other deposits."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Pollen analysis"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

