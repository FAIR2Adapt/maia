<http://connectivity-hub.com/terms/26bf4beb-2c35-4b32-942e-ca83749008ac>
        rdf:type           skos:Concept;
        dc:created         "2025-06-10T15:36:28.849Z"^^xsd:dateTime;
        dc:modified        "2025-06-10T15:38:40.899Z"^^xsd:dateTime;
        skos:altLabel      "GIS"@en , "geographical information systems"@en , "geographic information systems"@en;
        skos:definition    "Geographic Information Systems (GIS) connects data to a map, integrating location data with all types of descriptive information. This provides a foundation for mapping and analysis that is used in science and almost every industry. GIS helps users understand patterns, relationships, and geographic context. The benefits include improved communication, efficiency, management, and decision-making (Esri, n.d)."@en;
        skos:historyNote   "https://www.esri.com/en-us/what-is-gis/overview#:~:text=Geographic%20Information%20System%20(GIS)&text=Geographic%20information%20system(s)%2C%20GIS%20(noun)%20GIS%20is,descriptive%20information%20(what%20things%20are%20like%20there)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Geographic Information System"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      8 .

