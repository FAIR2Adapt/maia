<http://connectivity-hub.com/terms/d47d12a0-9476-4d3e-971f-c586be46c3dd>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/f53f11b2-1089-4686-86e9-ca79c69a168a>;
        skos:definition     "The global system consisting of five major components: the atmosphere, the hydrosphere, the cryosphere, the lithosphere and the biosphere and the interactions between them. The climate system changes in time under the influence of its own internal dynamics and because of external forcings such as volcanic eruptions, solar variations, orbital forcing, and anthropogenic forcings such as the changing composition of the atmosphere and land-use change."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Climate system"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

