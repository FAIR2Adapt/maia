<http://connectivity-hub.com/terms/5f680ecf-c23f-4e54-a937-8b756b498f95>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Long, narrow (up to a few hundred km wide), shallow (up to a few km deep) and transient corridors of strong horizontal water vapour transport that are typically associated with a low-level jet stream ahead of the cold front of an extratropical cyclone (ETC) (Ralph et al., 2018)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Atmospheric rivers (ARs)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

