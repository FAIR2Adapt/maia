<http://connectivity-hub.com/terms/c16f6d62-c1c2-4a74-a1dd-290aa6b135ab>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Model in which calculations are based on a combination of observed associations between variables and theoretical considerations relating variables through fundamental principles (e.g., conservation of energy). For example, in sea level studies, semi-empirical models refer specifically to transfer functions formulated to project future global mean sea level (GMSL) change, or contributions to it, from future global surface temperature change or radiative forcing (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Semi-empirical model"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

