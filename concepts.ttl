<http://connectivity-hub.com/terms/2cf76120-4506-4850-9c32-18fe78a63569>
        rdf:type           skos:Concept;
        dc:created         "2025-06-09T15:08:01.689Z"^^xsd:dateTime;
        dc:modified        "2025-06-09T15:11:18.257Z"^^xsd:dateTime;
        skos:definition    "LIDAR (Light Detection and Ranging), is a remote sensing method that can be used to generate detailed maps of topography and retrieve digital elevation data necessary for flood modelling and vulnerability and risks analysis. It uses a pulsed laser to measure and record three-dimensional information on the surface of the earth (topographic LIDAR), or the seafloor or riverbed (bathymetric LIDAR). The equipment is usually installed on an airplane, helicopter, or other airborne device, and includes a laser, scanner and GPS device (DHI, CTCN, UNEP DTU, 2017)."@en;
        skos:historyNote   "https://www.unepdhi.org/wp-content/uploads/sites/2/2020/05/CC_Adaptation_technologies_for_water_red.pdf"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "LiDAR"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      4 .

