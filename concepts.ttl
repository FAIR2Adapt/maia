<http://connectivity-hub.com/terms/3ac34b8b-9c98-45db-ad8d-91e46ff473fd>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The generic situation where decisions, events, or outcomes at one point in time constrain adaptation, mitigation or other actions or options at a later point in time."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Path dependence"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

