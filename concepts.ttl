<http://connectivity-hub.com/terms/0fbb3854-6174-440b-8d9a-21d347d5d130>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Area covered with grass or other plants used or suitable for grazing of livestock; grassland."@en;
