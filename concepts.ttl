<http://connectivity-hub.com/terms/848a329f-d4fd-4cb7-ba3b-4896fa078529>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Human actions to reduce carbon dioxide emissions from human activities. "@en;
