<http://connectivity-hub.com/terms/e6e4511e-8d8b-4be1-ad86-ccd4236b8a36>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The Inter-tropical Convergence Zone is an equatorial zonal belt of low pressure, strong convection and heavy precipitation near the equator where the north-east trade winds meet the south-east trade winds. This band moves seasonally."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Inter-tropical Convergence Zone (ITCZ)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

