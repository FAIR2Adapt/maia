<http://connectivity-hub.com/terms/786f3dc0-39f2-4264-8250-181375f0c9c8>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Extratropical jets are wind maxima in the upper troposphere marking zones of baroclinic instability. Anomalies in the position of these jets are often associated with storms, blocking, and weather extremes."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Extratropical jets"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

