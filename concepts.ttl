<http://connectivity-hub.com/terms/7157e038-fa54-475d-ad2b-37717e1dedf9>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The multi-century period prior to the onset of large-scale industrial activity around 1750. The reference period 1850–1900 is used to approximate pre-industrial global mean surface temperature (GMST)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Pre-industrial (period)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

