<http://connectivity-hub.com/terms/0f86e92a-ebff-4e96-b6da-82c013aeb62c>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A population, species or more inclusive taxonomic group has gone extinct when all its individuals have died. A species may go extinct locally (population extinction), regionally (e.g., extinction of all populations in a country, continent or ocean) or globally (IPBES, 2019)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Extinction"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

