<http://connectivity-hub.com/terms/5b298da2-959d-4f79-b5eb-0e4c194f7df5>
        rdf:type           skos:Concept;
        dc:created         "2025-06-06T14:39:22.324Z"^^xsd:dateTime;
        dc:modified        "2025-06-06T14:40:34.088Z"^^xsd:dateTime;
        skos:definition    "A transdisciplinary approach aimed at addressing the many ‘wicked’ problems confronting 21st century societies. Transition Design brings together two global memes. First, the idea that entire societies must transition toward more sustainable, equitable and desirable long-term futures and second, that these transitions will require intentional, systems-level change (Irwin and Kossoff, n.d)."@en;
        skos:historyNote   "Irwin, T., & Kossoff, G. (Instructors). (n.d.). Transition Design Seminar CMU. Carnegie Mellon University. https://transitiondesignseminarcmu.net"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Transition design"@en;
        skos:related       <http://connectivity-hub.com/terms/da886285-c496-4041-af60-2ea68f7219ec>;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      4 .

