<http://connectivity-hub.com/terms/cf95d071-f4bb-4b35-be40-ba2fe93fc0aa>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Assets exposed to devaluations or conversion to ‘liabilities’ because of unanticipated changes in their initially expected revenues due to innovations and/or evolutions of the business context, including changes in public regulations at the domestic and international levels."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Stranded assets"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

