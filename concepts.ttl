<http://connectivity-hub.com/terms/083e4731-556e-4012-810a-a961d2777362>
        rdf:type           skos:Concept;
        dc:created         "2024-08-29T11:35:00.811Z"^^xsd:dateTime;
        dc:modified        "2025-01-03T09:49:08.786Z"^^xsd:dateTime , "2024-08-29T11:37:26.422Z"^^xsd:dateTime;
        skos:altLabel      "agricultures"@en;
        skos:definition    "The production of plants and animals for human use, involving soil cultivation and the breeding and management of crops and livestock (adapted from GEMET). In the FAO Constitution, the term “agriculture” and its derivatives include fisheries, marine products, forestry, and primary forestry products (FAO, 2021)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:narrower      <http://connectivity-hub.com/terms/ebeaeee0-17c6-45f3-bf3c-eed0b1817575> , <http://connectivity-hub.com/terms/c037b86b-980d-4e0e-af70-9756eac819e9> , <http://connectivity-hub.com/terms/696ed25a-9c0c-4527-8daf-ca93a149a110> , <http://connectivity-hub.com/terms/bd6b6b51-65c9-4757-83ff-db3696d1bbf2>;
        skos:prefLabel     "Agriculture"@en;
        skos:scopeNote     "Agriculture is predominantly affected by meteorological and hydrological hazards, geohazards, environmental hazards and biological hazards, although societal hazards such as armed conflict, and technological and chemical hazards also pose potential threats. The amount of loss and damage produced by a disaster depends on the speed and spatial scale at which a hazard interacts with vulnerability and pre-existing risks, along with the amount of exposed assets or livelihoods (FAO, 2023)."@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      8 .

