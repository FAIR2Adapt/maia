<http://connectivity-hub.com/terms/a4b8b20a-693d-4b78-be48-e5ce8f05983a>
        rdf:type           skos:Concept;
        dc:created         "2025-06-10T15:44:17.953Z"^^xsd:dateTime;
        dc:modified        "2025-06-10T15:45:25.986Z"^^xsd:dateTime;
        skos:definition    "The maximum rate at which soils and rocks can absorb rainfall. The infiltration capacity tends to decrease as the soil moisture content of the surface layers increases. It also depends upon such factors as grain size and vegetation cover (A Dictionary of Ecology, 2015)."@en;
        skos:historyNote   "A Dictionary of Ecology DOI: 10.1093/acref/9780191793158.001.0001 Michael Allaby, 5th Edition."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Infiltration capacity"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      3 .

