<http://connectivity-hub.com/terms/809e20d2-3ae7-4bd9-8126-47efb5e3c996>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Downward motion of the land surface induced by anthropogenic drivers (e.g., loading, extraction of hydrocarbons and/or groundwater, drainage, mining activities) causing sediment compaction or subsidence/deformation of the sedimentary sequence, or oxidation of organic material, thereby leading to relative sea level rise."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Anthropogenic subsidence"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

