        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The reduction of the capacity of the environment to meet social and ecological objectives and needs. Degradation of the environment can alter the frequency and intensity of natural hazards and increase the vulnerability of communities (PreventionWeb, n.d., a. in Gill et al., 2022)."@en;
        skos:editorialNote  "source:UNDRR HIPS";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/f3ad9b19-c970-410b-8435-7e1456d8679b> , <http://connectivity-hub.com/terms/5cfd3ea3-6e8d-4629-a5c3-e748bc2c5dbd> , <http://connectivity-hub.com/terms/cc236b1c-27cf-4ce3-ba36-65da70b54c8a> , <http://connectivity-hub.com/terms/58bbe0d7-cf42-4a4d-86b4-d056b663e39c> , <http://connectivity-hub.com/terms/fa7bc4b6-9f14-4bdc-8f6b-4826203e8ece> , <http://connectivity-hub.com/terms/a907f126-c240-4785-9b7e-1fcc7ec82ba4> , <http://connectivity-hub.com/terms/133d2809-0006-43f3-bba4-46f7e992dd2b> , <http://connectivity-hub.com/terms/3d5e1330-f23d-430f-af05-3ec87a1513fb> , <http://connectivity-hub.com/terms/c9257a18-83ae-4f22-b7c2-463a99485b59> , <http://connectivity-hub.com/terms/86260091-10e6-4023-9c36-e8c625d3e08a>;
        skos:prefLabel      "Environmental degradation"@en;
        skos:related        <http://connectivity-hub.com/terms/8f15ed1e-9c86-4699-bb36-016354ce3cfc>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       8 .

