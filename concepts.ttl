<http://connectivity-hub.com/terms/aef81e7e-0911-4d2a-bca1-a457d62730eb>
        rdf:type            skos:Concept;
        dc:modified         "2025-06-05T15:05:31.857Z"^^xsd:dateTime;
        skos:definition     "A ‘serious disruption of the functioning of a community or a society at any scale due to hazardous events interacting with conditions of exposure, vulnerability and capacity, leading to one or more of the following: human, material, economic and environmental losses and impacts’ (IPCC AR6, 2023; UNGA, 2016)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/320a62d8-39d8-4d78-ab86-ef127aec8ee9>;
        skos:prefLabel      "Disaster"@en;
