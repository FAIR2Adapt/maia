<http://connectivity-hub.com/terms/e3865853-ec53-4f60-af2b-c41b40bff425>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The set of biophysical, cultural, socio-economic and political-institutional dimensions within which opportunities and constraints determine why, how, when and who acts to reduce climate risks. Within these dimensions, there are ’hard’ (unsurpassable) limits and ’soft’(surpassable) limits. The boundaries of the solution space are path dependent, contested and in constant flux (Haasnoot et. al. 2020)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Solution space"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

