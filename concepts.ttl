<http://connectivity-hub.com/terms/eaebe6d5-9eb7-4b39-a61a-ac5795d9631a>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:broader        <http://connectivity-hub.com/terms/430c45ee-88dc-4671-aa12-bc4af32d6c6a>;
        skos:definition     "A limit within the climate system (or its forcing) beyond which the behaviour of the system is qualitatively changed."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Climate threshold"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

