<http://connectivity-hub.com/terms/9d26105a-92a0-4c5e-98db-59b32e26bf5f>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "NMVOCs are major contributors (together with NOX and CO) to the formation of photochemical oxidants such as ozone."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Non-methane volatile organic compounds (NMVOCs)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

