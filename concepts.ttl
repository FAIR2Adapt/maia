<http://connectivity-hub.com/terms/274d0587-86ac-4715-ada9-5e9b407d8bfb>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A time period of interest, or a period over which some relevant statistics are calculated. A reference period can be used as a baseline period or as a comparison to a baseline period."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/a8923ab0-229a-4c72-ae03-aff302f0206c>;
        skos:prefLabel      "Reference period"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

