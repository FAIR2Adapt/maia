<http://connectivity-hub.com/terms/19a4c617-b262-47f5-b560-a8819282b679>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A particular interval of rapid global sea level rise between about 14,700 and 14,300 years ago, associated with the end of the last ice age and attributed to freshwater flux to the ocean from accelerated melting of ice sheets and glaciers. First defined based on oxygen isotope data (Duplessy et al., 1981), and later shown to be reflected by high rates of sea level rise (Fairbanks, 1989)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Meltwater Pulse 1A (MWP-1A)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

