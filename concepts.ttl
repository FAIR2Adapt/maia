<http://connectivity-hub.com/terms/8918f310-bc36-4465-a902-459a4f932d79>
        rdf:type           skos:Concept;
        dc:created         "2025-06-05T15:58:00.786Z"^^xsd:dateTime;
        dc:modified        "2025-06-05T16:02:29.688Z"^^xsd:dateTime;
        skos:definition    "A network of actors connected by social relationships, formal or informal, that dynamically combine knowing, doing, and learning to bring about specific actions for sustainable development’ (van Kerkhoff and Szlezák, 2010)."@en;
        skos:historyNote   "van Kerkhoff, L., & Szlezák, N. A. (2010). The role of innovative global institutions in linking knowledge and action. Proceedings of the National Academy of Sciences of the United States of America, 107(46), 4603–4608. https://doi.org/10.1073/pnas.0900541107\n\nCornell, S., Berkhout, F., Tuinstra, W., Tàbara, J. D., Jäger, J., Chabay, I., de Wit, B., Langlais, R., Mills, D., Moll, P., Otto, I. M., Petersen, A., Pohl, C., & van Kerkhoff, L. (2013). Opening up knowledge systems for better responses to global environmental change. Environmental Science & Policy, 28, 60–70. https://doi.org/10.1016/j.envsci.2012.11.008"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Knowledge systems"@en;
        skos:scopeNote     "Relationships within knowledge systems shape the flows of knowledge, credibility and power within those systems (Cornell et al., 2013)."@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      7 .

