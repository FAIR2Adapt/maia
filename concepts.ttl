<http://connectivity-hub.com/terms/c549b3aa-3c1d-4f56-a631-a78c0ea8e0bf>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The structures, processes and actions through which private and public actors interact to address societal goals. This includes formal and informal institutions and the associated norms, rules, laws and procedures for deciding, managing, implementing and monitoring policies and measures at any geographic or political scale, from global to local."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/d384ec88-9b64-4334-811a-e7b196e7948a> , <http://connectivity-hub.com/terms/31b591a2-23bf-4cf7-bcfb-5eef2000fe1e> , <http://connectivity-hub.com/terms/6bb95c4b-d2e1-410e-90c4-5bf9aff0ddc0> , <http://connectivity-hub.com/terms/967e7ba1-629f-4b96-bf92-3f01611ca2b6> , <http://connectivity-hub.com/terms/eb631de7-bf23-4ef9-b8d0-ef63e26eaad4> , <http://connectivity-hub.com/terms/0921140a-51a7-4895-9277-3a479b5d2279> , <http://connectivity-hub.com/terms/5c32a59f-f6ac-4fa5-9d71-08fa95c0a3e8> , <http://connectivity-hub.com/terms/c564377e-6ad9-4283-bc54-893a143dfee6>;
