<http://connectivity-hub.com/terms/73035aaf-3bf1-437b-8aec-77996180cd1d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The equilibrium (steady state) change in the surface temperature following a doubling of the atmospheric carbon dioxide (CO2) concentration from pre-industrial conditions."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Equilibrium climate sensitivity (ECS)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

