<http://connectivity-hub.com/terms/ba624df3-ae07-4584-82d6-4e93fd46fefe>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Phenomena whereby the reduction in energy consumption or emissions (relative to a baseline) associated with the implementation of mitigation measures in a jurisdiction is offset to some degree through induced changes in consumption, production, and prices within the same jurisdiction. The rebound effect is most typically ascribed to technological energy efficiency improvements."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Rebound effect"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

PREFIX acl:     <https://graphifi.com/schema/accesscontrol/>
PREFIX dc:      <http://purl.org/dc/terms/>
PREFIX dct:     <http://purl.org/dc/terms/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dme:     <https://grafsync.graphifi.com/schema/dm-entitlement/>
PREFIX ent:     <https://graphifi.com/schema/entitlement/>
PREFIX gs:      <https://grafsync.graphifi.com/schema/gs/>
PREFIX ome:     <https://grafsync.graphifi.com/schema/om-entitlement/>
PREFIX owl:     <http://www.w3.org/2002/07/owl#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
