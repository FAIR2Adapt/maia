<http://connectivity-hub.com/terms/3b4373bc-1dae-4f7d-b19e-6f676cf71cf6>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The Pliocene Epoch is the more recent of two epochs of the Neogene Period within the Cenozoic Era. It extends from 5.33 Ma to the beginning of the Pleistocene Epoch at 2.59 Ma. The Neogene Period precedes the current geological period, the Quaternary Period, which is one of several ice ages that have occurred during Earth’s geological history. It encompasses the mid-Pliocene warm period (MPWP), also known as the Piacenzian warm period, which occurred from approximately 3.3 to 3.0 Ma. The MPWP, in turn, encompasses the interglacial episode, marine isotope stage (MIS) KM5c, which peaked at 3.205 Ma, when orbital forcing was similar to modern (Haywood et al., 2016)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Pliocene"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

