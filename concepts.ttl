<http://connectivity-hub.com/terms/b937b740-5a1c-42d9-a8d2-d7308199bacc>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The supreme body of UN conventions, such as the United Nations Framework Convention on Climate Change (UNFCCC), comprising parties with a right to vote that have ratified or acceded to the convention."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Conference of the Parties (COP)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

