<http://connectivity-hub.com/terms/85886ce2-578b-4078-92df-9d8cd7e6a6bc>
        rdf:type           skos:Concept;
        dc:created         "2024-11-29T15:43:18.288Z"^^xsd:dateTime;
        dc:modified        "2025-01-03T09:50:23.717Z"^^xsd:dateTime;
        skos:definition    "Cross sectoral dependencies can be defined as relationships (either correlated or otherwise) between two or more sectors of the economy (Gill et al., 2022)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Cross-sectoral"@en;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      4 .

