<http://connectivity-hub.com/terms/f8c3d5a4-9190-4775-955a-01eea12d25fa>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A technique for measuring the height of the Earth’s surface with respect to the geocentre of the Earth within a defined terrestrial reference frame (geocentric sea level)."@en;
