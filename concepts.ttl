<http://connectivity-hub.com/terms/62a4d892-5101-4bf8-aed0-20b527674207>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The boundary between the troposphere and the stratosphere. It ranges from 8–9 km at high latitudes to 15–16 km in the tropics."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Tropopause"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

