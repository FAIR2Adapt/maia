<http://connectivity-hub.com/terms/21b89464-df5f-478f-9143-acd3f8e6a342>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Conditions of low dissolved oxygen in shallow water ocean and freshwater environments. There is no universal threshold for hypoxia. A value around 60 μmol kg–1 has commonly been used for some estuarine systems, although this does not necessarily directly translate into biological impacts. Anoxic conditions occur where there is no oxygen present at all."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Hypoxic"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

