<http://connectivity-hub.com/terms/c4548efa-eb7e-4297-8f80-c43f83a81ec5>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Soft, porous or compressed, sedentary deposit of which a substantial portion is partly decomposed plant material with high water content in the natural state (up to about 90%)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Peat"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

