<http://connectivity-hub.com/terms/fc501a7b-2d4f-4f0a-8e6a-c0fb1d19437f>
        rdf:type           skos:Concept;
        dc:created         "2025-06-05T14:23:39.562Z"^^xsd:dateTime;
        dc:modified        "2025-06-05T14:30:41.497Z"^^xsd:dateTime;
        skos:definition    "A causal chain with many intervening variables and feedback loops that do not allow the understanding or prediction of the system’s behaviour on the basis of each component’s behaviour (Aven, 2019 in Gill et al., 2022)."@en;
        skos:historyNote   "Myriad-EU glossary"@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Complexity"@en;
        skos:related       <http://connectivity-hub.com/terms/2f2bf4de-7b28-49a6-a9a1-b3eb0ef0e9ef>;
        skos:topConceptOf  <http://connectivity-hub.com/terms/>;
        gs:revisionNo      6 .

