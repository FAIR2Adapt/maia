<http://connectivity-hub.com/terms/75e53cc0-77b2-4a0d-9aeb-99e75ec8f04b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Layer of ground above permafrost subject to annual thawing and freezing (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Active layer"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

