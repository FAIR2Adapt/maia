<http://connectivity-hub.com/terms/53aa0e30-b617-406a-86e2-261241458d37>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The change in the portfolio of risks that occurs when a countervailing risk is generated (knowingly or inadvertently) by an intervention to reduce the target risk (Wiener and Graham, 2009)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Risk trade-off"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

