<http://connectivity-hub.com/terms/1dbe3980-c16d-47bd-818b-150bae30ef0b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The temporal evolution of natural and/or human systems towards a future state. Pathway concepts range from sets of quantitative and qualitative scenarios or narratives of potential futures to solution-oriented decision-making processes to achieve desirable societal goals. Pathway approaches typically focus on biophysical, techno-economic, and/or socio-behavioural trajectories and involve various dynamics, goals, and actors across different scales (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/d8f2c82a-d85e-44dd-a9f6-ed5a1498b827> , <http://connectivity-hub.com/terms/1aaf3639-ae98-4b2f-8bce-6429d88ee749> , <http://connectivity-hub.com/terms/2bc764bb-860a-4d14-814d-72b8bdd68012> , <http://connectivity-hub.com/terms/87723bec-f29d-4ff3-87ed-d14dc4fa1981> , <http://connectivity-hub.com/terms/7361f763-e600-4532-a343-cf7c98ac4dae> , <http://connectivity-hub.com/terms/2d64d3a7-3e24-4ba2-988a-6a72b5533e67> , <http://connectivity-hub.com/terms/411609bc-7b0d-413b-a6c2-b8f46e73de65> , <http://connectivity-hub.com/terms/a7a8a85e-dcc9-4945-8181-6ac33ca68ed9> , <http://connectivity-hub.com/terms/4a98e5e1-bead-4766-8bf0-bcd83cafd6c6> , <http://connectivity-hub.com/terms/ee8b0c2e-3a8a-4186-b288-a0b318ec3474>;
        skos:prefLabel      "Pathways"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

