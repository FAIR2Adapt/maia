<http://connectivity-hub.com/terms/52d58acc-a42f-4024-8282-868c6bf6541f>
        rdf:type           skos:Concept;
        dc:created         "2024-11-29T11:40:55.57Z"^^xsd:dateTime;
        dc:modified        "2025-06-06T14:32:17.712Z"^^xsd:dateTime;
        skos:altLabel      "systems based thinking"@en , "Systems thinking approach"@en , "Systemic perspective"@en , "systems approach. systems thinking"@en;
        skos:definition    "An approach to problem-solving or a focus on the overall system i.e. interactions between elements within a ‘System’ (or Systems) (adapted from: Gill et al., 2022)."@en;
        skos:inScheme      <http://connectivity-hub.com/terms/>;
        skos:prefLabel     "Systems thinking"@en;
        skos:related       <http://connectivity-hub.com/terms/b5e890c1-8af4-4a42-ac48-da67de1ae773> , <http://connectivity-hub.com/terms/da886285-c496-4041-af60-2ea68f7219ec>;
