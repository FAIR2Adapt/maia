<http://connectivity-hub.com/terms/7e3f45b0-6cda-403c-be9f-6b357b3d70a5>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A direct, thermally driven overturning cell in the atmosphere consisting of poleward flow in the upper troposphere, subsiding air into the subtropical anticyclones, return flow as part of the trade winds near the surface, and with rising air near the equator in the so-called Inter-tropical Convergence Zone."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Hadley circulation"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

