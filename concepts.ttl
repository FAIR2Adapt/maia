<http://connectivity-hub.com/terms/69b92861-bfa4-4228-a71e-33758a06f0d8>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Wavelength-dependent aerosol optical depth is a measure of the aerosol contribution to extinction of top-of-the-atmosphere solar intensity measured at the ground. AOD is unitless (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/bb661721-193b-45cc-8fb3-438c8d1de123>;
        skos:prefLabel      "Aerosol optical depth (AOD)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

