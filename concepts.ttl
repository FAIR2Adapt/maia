<http://connectivity-hub.com/terms/99d92e69-61ce-4736-8467-4099e5cd6f72>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A set of measures and daily practices that avoid demand for energy, materials, land and water while delivering human well-being for all within planetary boundaries."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Sufficiency"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

