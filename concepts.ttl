<http://connectivity-hub.com/terms/e6ec781b-c9b0-4ed7-a0ee-d9ff460e64a8>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Plant evaporative stress in both crops and natural vegetation can result from the combination of a high atmospheric evaporative demand and limited available water to supply this demand by means of evapotranspiration, further enhancing agricultural and ecological drought."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Plant evaporative stress"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

