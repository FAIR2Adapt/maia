<http://connectivity-hub.com/terms/f59bc93b-78fd-40dd-8820-68a172e3bf18>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The large-scale motions of the atmosphere and the ocean as a consequence of differential heating on a rotating Earth. General circulation contributes to the energy balance of the system through transport of heat and momentum."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "General circulation"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

