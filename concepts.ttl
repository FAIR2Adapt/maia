<http://connectivity-hub.com/terms/5f9d5403-c36d-4648-bf3e-2003d06e7b9e>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The flow of carbon (in various forms, e.g., as carbon dioxide (CO2), carbon in biomass, and carbon dissolved in the ocean as carbonate and bicarbonate) through the atmosphere, hydrosphere, terrestrial and marine biosphere and lithosphere. In this report, the reference unit for the global carbon cycle is GtCO2 or GtC (one Gigatonne = 1 Gt = 1015 grams; 1 GtC corresponds to 3.664 GtCO2)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Carbon cycle"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
