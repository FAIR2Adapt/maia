<http://connectivity-hub.com/terms/5e54dd75-11b2-4f12-a502-659267c332da>
        rdf:type            skos:Concept;
        dc:modified         "2025-05-28T14:36:08.412Z"^^xsd:dateTime;
        skos:definition     "Simulated response of the climate system to a scenario of future emissions or concentrations of greenhouse gases (GHGs) and aerosols and changes in land use, generally derived using climate models. Climate projections are distinguished from climate predictions by their dependence on the emission/concentration/radiative forcing scenario used, which is in turn based on assumptions concerning, for example, future socio-economic and technological developments that may or may not be realised."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Climate projection"@en;
        skos:related        <http://connectivity-hub.com/terms/ba00e68b-0e44-4705-b76c-d2635df35433>;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

