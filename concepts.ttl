<http://connectivity-hub.com/terms/f9449e4c-7793-48c9-b059-170e923beb24>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The breaking off of discrete pieces of ice from a glacier, ice sheet or an ice shelf into lake or seawater, producing icebergs. This is a form of mass loss from an ice body."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Calving (of glaciers or ice sheets)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

