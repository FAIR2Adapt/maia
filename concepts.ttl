<http://connectivity-hub.com/terms/048d5918-d295-464b-b232-e592717eae54>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Outcomes/events whose probability of occurrence is low or not well known (as in the context of deep uncertainty) but whose potential impacts on society and ecosystems could be high. To better inform risk assessment and decision-making, such low-likelihood outcomes are considered if they are associated with very large consequences and may therefore constitute material risks, even though those consequences do not necessarily represent the most likely outcome."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Low-likelihood, high impact outcomes"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

