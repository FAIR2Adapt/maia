<http://connectivity-hub.com/terms/e420fe93-64e6-4cac-9e1c-1d1c400ea2cf>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Increasing yields from the same area of land while decreasing negative environmental impacts of agricultural production and increasing the provision of environmental services (CGIAR, 2019). [Note: This definition is based on the concept of meeting demand from a finite land area, but it is scale-dependent. Sustainable intensification at a given scale (e.g., global or national) may require a decrease in production intensity at smaller scales and in particular places (often associated with previous, unsustainable, intensification) to achieve sustainability (Garnett et al., 2013).]"@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Sustainable intensification (of agriculture)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

