<http://connectivity-hub.com/terms/f7f4f96d-d5ad-48b6-99eb-6d0094e9a22d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "Atmospheric compounds that are not greenhouse gases (GHGs) or aerosols, but that have an effect on GHG or aerosol concentrations by taking part in physical or chemical processes regulating their production or destruction rates."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Precursors"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

