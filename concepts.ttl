<http://connectivity-hub.com/terms/bc929a4c-eba7-4e98-b76f-350fb146a03d>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "A human intervention to reduce emissions or enhance the sinks of greenhouse gases (IPCC AR6, 2023)."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:narrower       <http://connectivity-hub.com/terms/17b655bf-7ce3-4d74-9eb8-4df6b7c0fe27> , <http://connectivity-hub.com/terms/71c58494-73c7-4bb8-9845-5375ae1edaab>;
        skos:prefLabel      "Mitigation (of climate change)"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       2 .

