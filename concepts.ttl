<http://connectivity-hub.com/terms/93d36108-f5a4-48af-b39f-4820482d4ef9>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "An ice sheet containing a substantial region that rests on a bed lying below sea level and whose perimeter is in contact with the ocean. The best known example is the West Antarctic Ice Sheet."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Marine-based ice sheet"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

