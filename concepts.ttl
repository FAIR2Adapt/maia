<http://connectivity-hub.com/terms/8f9a9ac4-9f8f-42ba-a26f-fee39c322c2b>
        rdf:type            skos:Concept;
        dc:modified         "2025-03-14T12:00:44.313Z"^^xsd:dateTime;
        skos:definition     "The process whereby living organisms convert organic matter to carbon dioxide (CO2), releasing energy and consuming molecular oxygen."@en;
        skos:editorialNote  "source:IPCC Glossary AR6";
        skos:inScheme       <http://connectivity-hub.com/terms/>;
        skos:prefLabel      "Respiration"@en;
        skos:topConceptOf   <http://connectivity-hub.com/terms/>;
        gs:revisionNo       1 .

